{
  "name": "casino-premium-theme",
  "type": "module",
  "version": "1.0.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "NODE_OPTIONS=--max-old-space-size=4096 tinacms dev -c \"astro dev\"",
    "dev:astro": "astro dev",
    "cms:build": "node scripts/tina-build.mjs",
    "build": "npm run cms:build && astro build",
    "build:cloudflare": "npm run cms:build && ASTRO_SITE=https://macau3.zhuanqian388.workers.dev ASTRO_BASE=/ astro build",
    "build:github": "npm run cms:build && ASTRO_SITE=https://daikao1688-maker.github.io ASTRO_BASE=/macau3 astro build",
    "preview": "npm run build && wrangler dev",
    "astro": "astro",
    "generate-types": "wrangler types",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.0.1",
    "@astrojs/react": "^6.0.0",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.0.3",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@tinacms/cli": "^2.5.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.5.2",
    "postcss": "^8.5.15",
    "tinacms": "^3.9.3",
    "typescript": "^5.7.2",
    "wrangler": "^4.105.0"
  },
  "overrides": {
    "linkify-it": "^5.0.1",
    "lodash": "^4.18.1",
    "markdown-it": "^14.2.0"
  }
}
