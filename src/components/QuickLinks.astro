---
import { withBase } from '../utils/paths';
// Quick Links to Premium Pages
---

<section class="section-padding bg-gradient-to-b from-dark-950 via-dark-900 to-dark-950 relative overflow-hidden">
  <!-- Background Effects -->
  <div class="absolute top-0 right-1/4 w-96 h-96 bg-primary-500/5 rounded-full blur-3xl"></div>
  <div class="absolute bottom-0 left-1/4 w-96 h-96 bg-secondary-500/5 rounded-full blur-3xl"></div>
  
  <div class="container mx-auto relative z-10">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-display font-bold mb-4">
        <span class="text-gradient">Explore More</span>
      </h2>
      <p class="text-gray-400 max-w-2xl mx-auto">
        Discover our complete casino experience with premium features
      </p>
    </div>

    <!-- Quick Links Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Providers -->
      <a 
        href={withBase('/providers')} 
        class="group bg-gradient-to-br from-gray-800/80 to-gray-900/80 backdrop-blur-sm rounded-2xl p-8 border border-gray-700/50 hover:border-amber-500/50 transition-all duration-300 hover-lift"
      >
        <div class="text-5xl mb-4">🎮</div>
        <h3 class="text-2xl font-bold text-white mb-3 group-hover:text-amber-400 transition-colors">
          Game Providers
        </h3>
        <p class="text-gray-400 mb-4">
          Explore games from 8+ world-class providers including NetEnt, Evolution Gaming, and Pragmatic Play
        </p>
        <div class="flex items-center text-amber-400 font-semibold">
          <span>View All Providers</span>
          <svg class="w-5 h-5 ml-2 group-hover:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </div>
      </a>

      <!-- Live Casino -->
      <a 
        href={withBase('/live-casino')} 
        class="group bg-gradient-to-br from-gray-800/80 to-gray-900/80 backdrop-blur-sm rounded-2xl p-8 border border-gray-700/50 hover:border-red-500/50 transition-all duration-300 hover-lift"
      >
        <div class="flex items-center gap-2 text-5xl mb-4">
          <span>🎥</span>
          <span class="relative flex h-3 w-3">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-3 w-3 bg-red-500"></span>
          </span>
        </div>
        <h3 class="text-2xl font-bold text-white mb-3 group-hover:text-red-400 transition-colors">
          Live Casino
        </h3>
        <p class="text-gray-400 mb-4">
          Join professional dealers streaming live 24/7 in stunning 4K quality with real-time interaction
        </p>
        <div class="flex items-center text-red-400 font-semibold">
          <span>Join Live Tables</span>
          <svg class="w-5 h-5 ml-2 group-hover:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </div>
      </a>

      <!-- Jackpots -->
      <a 
        href={withBase('/jackpots')} 
        class="group bg-gradient-to-br from-gray-800/80 to-gray-900/80 backdrop-blur-sm rounded-2xl p-8 border border-gray-700/50 hover:border-amber-500/50 transition-all duration-300 hover-lift relative overflow-hidden"
      >
        <div class="absolute top-0 right-0 px-3 py-1 bg-amber-500/20 border-l border-b border-amber-500/50 rounded-bl-xl">
          <span class="text-amber-400 text-xs font-bold animate-pulse">HOT</span>
        </div>
        <div class="text-5xl mb-4">💰</div>
        <h3 class="text-2xl font-bold text-white mb-3 group-hover:text-amber-400 transition-colors">
          Progressive Jackpots
        </h3>
        <p class="text-gray-400 mb-4">
          Chase life-changing wins with jackpots reaching millions. Total pool: $16.7M+
        </p>
        <div class="flex items-center text-amber-400 font-semibold">
          <span>Play Jackpot Games</span>
          <svg class="w-5 h-5 ml-2 group-hover:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </div>
      </a>
    </div>
  </div>
</section>
