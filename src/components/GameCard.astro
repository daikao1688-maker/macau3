---
interface Props {
  id: string;
  title: string;
  category: string;
  image: string;
  jackpot?: number | null;
  rating: number;
  players: number;
  hot: boolean;
  new?: boolean;
  provider?: string;
  rtp?: number;
  slug: string;
}

const { 
  id,
  title, 
  category, 
  image, 
  jackpot, 
  rating, 
  players, 
  hot, 
  new: isNew = false,
  provider = 'Premium', 
  rtp = 96,
  slug
} = Astro.props;

// Format player count
const formatPlayerCount = (count: number) => {
  if (count >= 1000000) {
    return `${(count / 1000000).toFixed(1)}M`;
  } else if (count >= 1000) {
    return `${(count / 1000).toFixed(1)}K`;
  }
  return count.toString();
};

// Format jackpot amount
const formatJackpot = (amount: number) => {
  if (amount >= 1000000) {
    return `$${(amount / 1000000).toFixed(1)}M`;
  } else if (amount >= 1000) {
    return `$${(amount / 1000).toFixed(0)}K`;
  }
  return `$${amount}`;
};
---

<div class="card-glass group hover:scale-105 transition-all duration-300 overflow-hidden cursor-pointer h-full flex flex-col">
  <!-- Image Container -->
  <div class="relative overflow-hidden aspect-video flex-shrink-0">
    <!-- Fallback gradient background -->
    <div class="absolute inset-0 bg-gradient-to-br from-primary-500/30 via-secondary-500/30 to-accent-pink/30">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(245,158,11,0.3),transparent_50%)]"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_80%_20%,rgba(99,102,241,0.3),transparent_50%)]"></div>
    </div>
    
    <!-- Real Casino Image -->
    <img 
      src={`https://images.unsplash.com/photo-${
        title.includes('Mega Fortune') || title.includes('Dreams') ? '1596838132731-3301c3fd4317' :
        title.includes('Blackjack') || title.includes('VIP') ? '1541278107931-e006523892df' :
        title.includes('Lightning') || title.includes('Roulette') ? '1596838132731-3301c3fd4317' :
        title.includes('Book of Ra') || title.includes('Deluxe') ? '1596838132731-3301c3fd4317' :
        title.includes('Poker') || title.includes('Hold') ? '1541278107931-e006523892df' :
        title.includes('Starburst') || title.includes('XXXtreme') ? '1596838132731-3301c3fd4317' :
        title.includes('Crazy Time') ? '1596838132731-3301c3fd4317' :
        title.includes('Gonzo') || title.includes('Megaways') ? '1596838132731-3301c3fd4317' :
        title.includes('Immersive') ? '1596838132731-3301c3fd4317' :
        '1596838132731-3301c3fd4317'
      }?w=800&h=600&fit=crop&q=80`}
      alt={title}
      class="absolute inset-0 w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-700 z-10"
      loading="lazy"
    />
    
    <!-- Gradient Overlay -->
    <div class="absolute inset-0 bg-gradient-to-br from-primary-500/20 via-secondary-500/20 to-transparent z-20"></div>
    
    <!-- Dark overlay for better text visibility -->
    <div class="absolute inset-0 bg-gradient-to-t from-dark-950 via-dark-950/70 to-transparent opacity-70 group-hover:opacity-50 transition-opacity duration-300 z-20"></div>
    
    <!-- Hot Badge -->
    {hot && (
      <div class="absolute top-4 left-4 z-30 bg-gradient-to-r from-accent-red to-orange-600 text-white text-xs font-bold px-4 py-2 rounded-full animate-pulse shadow-lg backdrop-blur-sm">
        🔥 HOT
      </div>
    )}

    <!-- New Badge -->
    {isNew && (
      <div class="absolute top-4 left-4 z-30 bg-gradient-to-r from-accent-green to-emerald-600 text-white text-xs font-bold px-4 py-2 rounded-full shadow-lg backdrop-blur-sm" style={hot ? 'top: 3.5rem;' : ''}>
        ✨ NEW
      </div>
    )}

    <!-- Jackpot Badge -->
    {jackpot && jackpot > 0 && (
      <div class="absolute top-4 right-4 z-30">
        <div class="bg-gradient-to-r from-primary-500 to-yellow-500 text-white text-xs font-bold px-4 py-2 rounded-full glow-box shadow-lg animate-float backdrop-blur-sm">
          <span class="jackpot-counter" data-initial={jackpot}>
            💰 {formatJackpot(jackpot)}
          </span>
        </div>
      </div>
    )}

    <!-- Play Button -->
    <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300 z-30">
      <div class="flex space-x-3">
        <button 
          class="game-detail-btn bg-gradient-to-r from-secondary-500 to-secondary-600 hover:from-secondary-600 hover:to-secondary-700 text-white rounded-full p-6 transform scale-0 group-hover:scale-100 transition-transform duration-300 shadow-2xl backdrop-blur-sm"
          data-game-id={id}
          title="View Details"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </button>
        
        <button 
          class="play-demo-btn bg-gradient-to-r from-amber-500 to-amber-600 hover:from-amber-600 hover:to-amber-700 text-white rounded-full p-6 transform scale-0 group-hover:scale-100 transition-transform duration-300 shadow-2xl backdrop-blur-sm" 
          style="transition-delay: 0.05s;"
          data-game-id={id}
          title="Play Demo"
        >
          <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20">
            <path d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z"/>
          </svg>
        </button>
        
        <button 
          class="bg-gradient-to-r from-primary-500 to-primary-600 hover:from-primary-600 hover:to-primary-700 text-white rounded-full p-6 transform scale-0 group-hover:scale-100 transition-transform duration-300 shadow-2xl backdrop-blur-sm" 
          style="transition-delay: 0.1s;"
          title="Play Now"
        >
          <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
            <path d="M8 5v14l11-7z"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Content -->
  <div class="p-6 flex flex-col flex-grow">
    <!-- Provider & RTP -->
    <div class="flex items-center justify-between text-xs mb-4">
      <span class="px-3 py-1 bg-white/5 rounded-full text-gray-400 border border-white/10">
        {provider}
      </span>
      <span class="px-3 py-1 bg-accent-green/10 rounded-full text-accent-green font-semibold border border-accent-green/30">
        RTP {rtp}%
      </span>
    </div>

    <!-- Title & Category -->
    <div class="mb-4">
      <h3 class="text-xl font-display font-bold text-white mb-1 group-hover:text-primary-500 transition-colors line-clamp-2 min-h-[3.5rem]">
        {title}
      </h3>
      <p class="text-sm text-gray-400 font-medium line-clamp-1">{category}</p>
    </div>

    <!-- Stats -->
    <div class="flex items-center justify-between text-sm pt-2 border-t border-white/10 mb-4">
      <div class="flex items-center space-x-1">
        <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
        </svg>
        <span class="text-white font-bold">{rating}</span>
        <span class="text-gray-400">/5</span>
      </div>
      <div class="flex items-center space-x-1 text-gray-400">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
        </svg>
        <span class="font-semibold text-white player-count" data-count={players}>{formatPlayerCount(players)}</span>
        <span class="text-xs">playing</span>
      </div>
    </div>

    <!-- Buttons Area - Always at bottom -->
    <div class="mt-auto space-y-2">
      <!-- Play Button -->
      <button class="w-full bg-gradient-to-r from-primary-500 to-primary-600 hover:from-primary-600 hover:to-primary-700 text-white font-bold py-3 rounded-lg transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-primary-500/50 relative overflow-hidden group/btn">
        <span class="relative z-10">Play Now</span>
        <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent transform -skew-x-12 -translate-x-full group-hover/btn:translate-x-full transition-transform duration-700"></div>
      </button>

      <!-- Quick Info Button -->
      <button 
        class="game-info-btn w-full bg-white/5 hover:bg-white/10 text-gray-300 hover:text-white font-semibold py-2 rounded-lg transition-all duration-300 border border-white/10 hover:border-primary-500/50 text-sm"
        data-game-id={id}
      >
        View Details
      </button>
    </div>
  </div>
</div>

<style>
  .line-clamp-1 {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script>
  // Dynamic player count and jackpot updates
  document.addEventListener('DOMContentLoaded', () => {
    // Update player counts dynamically
    const updatePlayerCounts = () => {
      const playerCountElements = document.querySelectorAll('.player-count[data-count]');
      
      playerCountElements.forEach(element => {
        const baseCount = parseInt(element.getAttribute('data-count') || '0');
        const variation = Math.floor(Math.random() * 200) - 100; // ±100 players
        const newCount = Math.max(0, baseCount + variation);
        
        // Format the count
        let formattedCount;
        if (newCount >= 1000000) {
          formattedCount = `${(newCount / 1000000).toFixed(1)}M`;
        } else if (newCount >= 1000) {
          formattedCount = `${(newCount / 1000).toFixed(1)}K`;
        } else {
          formattedCount = newCount.toString();
        }
        
        element.textContent = formattedCount;
        
        // Add subtle animation
        element.style.transform = 'scale(1.05)';
        element.style.color = '#10b981';
        
        setTimeout(() => {
          element.style.transform = 'scale(1)';
          element.style.color = '';
        }, 300);
      });
    };

    // Update jackpot counters
    const updateJackpots = () => {
      const jackpotElements = document.querySelectorAll('.jackpot-counter[data-initial]');
      
      jackpotElements.forEach(element => {
        const initialAmount = parseInt(element.getAttribute('data-initial') || '0');
        const increment = Math.floor(Math.random() * 100) + 10; // $10-$110 increment
        const newAmount = initialAmount + increment;
        
        // Update the data attribute
        element.setAttribute('data-initial', newAmount.toString());
        
        // Format the amount
        let formattedAmount;
        if (newAmount >= 1000000) {
          formattedAmount = `$${(newAmount / 1000000).toFixed(1)}M`;
        } else if (newAmount >= 1000) {
          formattedAmount = `$${(newAmount / 1000).toFixed(0)}K`;
        } else {
          formattedAmount = `$${newAmount}`;
        }
        
        element.innerHTML = `💰 ${formattedAmount}`;
        
        // Add animation
        element.parentElement?.classList.add('animate-pulse');
        element.style.transform = 'scale(1.1)';
        element.style.color = '#fbbf24';
        
        setTimeout(() => {
          element.parentElement?.classList.remove('animate-pulse');
          element.style.transform = 'scale(1)';
          element.style.color = '';
        }, 500);
      });
    };

    // Initial update
    setTimeout(updatePlayerCounts, 2000);
    setTimeout(updateJackpots, 5000);
    
    // Set intervals for continuous updates
    setInterval(updatePlayerCounts, 15000); // Every 15 seconds
    setInterval(updateJackpots, 8000); // Every 8 seconds
  });
</script>
