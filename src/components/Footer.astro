        <h3 class="text-white font-display font-bold text-lg mb-6">Casino</h3>
        <ul class="space-y-3">
          <li><a href={withBase('/games')} class="text-gray-400 hover:text-primary-500 transition-colors">All Games</a></li>
          <li><a href={withBase('/slots')} class="text-gray-400 hover:text-primary-500 transition-colors">Slots</a></li>
          <li><a href={withBase('/live-casino')} class="text-gray-400 hover:text-primary-500 transition-colors">Live Casino</a></li>
          <li><a href={withBase('/jackpots')} class="text-gray-400 hover:text-primary-500 transition-colors">Jackpots</a></li>
          <li><a href={withBase('/providers')} class="text-gray-400 hover:text-primary-500 transition-colors">Providers</a></li>
          <li><a href={withBase('/tournaments')} class="text-gray-400 hover:text-primary-500 transition-colors">Tournaments</a></li>
        </ul>
      </div>

      <!-- Support -->
      <div>
        <h3 class="text-white font-display font-bold text-lg mb-6">Support</h3>
        <ul class="space-y-3">
          <li><a href={withBase('/help-center')} class="text-gray-400 hover:text-primary-500 transition-colors">Help Center</a></li>
          <li><a href={withBase('/contact-us')} class="text-gray-400 hover:text-primary-500 transition-colors">Contact Us</a></li>
          <li><a href={withBase('/faq')} class="text-gray-400 hover:text-primary-500 transition-colors">FAQ</a></li>
          <li><a href={withBase('/payment-methods')} class="text-gray-400 hover:text-primary-500 transition-colors">Payment Methods</a></li>
          <li><a href={withBase('/responsible-gaming')} class="text-gray-400 hover:text-primary-500 transition-colors">Responsible Gaming</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="text-white font-display font-bold text-lg mb-6">Legal</h3>
        <ul class="space-y-3">
          <li><a href={withBase('/about-us')} class="text-gray-400 hover:text-primary-500 transition-colors">About Us</a></li>
          <li><a href={withBase('/terms-and-conditions')} class="text-gray-400 hover:text-primary-500 transition-colors">Terms & Conditions</a></li>
          <li><a href={withBase('/privacy-policy')} class="text-gray-400 hover:text-primary-500 transition-colors">Privacy Policy</a></li>
          <li><a href={withBase('/cookie-policy')} class="text-gray-400 hover:text-primary-500 transition-colors">Cookie Policy</a></li>
          <li><a href={withBase('/licenses')} class="text-gray-400 hover:text-primary-500 transition-colors">Licenses</a></li>
        </ul>
      </div>
    </div>

    <!-- Payment Methods -->
    <div class="border-t border-white/10 pt-8 mb-8">
      <h4 class="text-white font-semibold mb-4 text-center">Accepted Payment Methods</h4>
      <div class="flex flex-wrap justify-center items-center gap-6 opacity-60">
        <div class="bg-white/10 px-6 py-3 rounded-lg text-gray-400 text-sm">Visa</div>
        <div class="bg-white/10 px-6 py-3 rounded-lg text-gray-400 text-sm">Mastercard</div>
        <div class="bg-white/10 px-6 py-3 rounded-lg text-gray-400 text-sm">Bitcoin</div>
        <div class="bg-white/10 px-6 py-3 rounded-lg text-gray-400 text-sm">Ethereum</div>
        <div class="bg-white/10 px-6 py-3 rounded-lg text-gray-400 text-sm">PayPal</div>
        <div class="bg-white/10 px-6 py-3 rounded-lg text-gray-400 text-sm">Skrill</div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-white/10 pt-8 text-center">
      <p class="text-gray-500 text-sm mb-4">
        © {currentYear} CasinoPro. All rights reserved. Licensed and regulated by the Gaming Authority.
      </p>
      <p class="text-gray-600 text-xs max-w-4xl mx-auto">
        18+ only. Gambling can be addictive. Please play responsibly. BeGambleAware.org
      </p>
    </div>
  </div>
</footer>
