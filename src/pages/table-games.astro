const categories = [
  { name: 'All Games', count: '150+', icon: '🎲' },
  { name: 'Roulette', count: '45+', icon: '🎡' },
  { name: 'Blackjack', count: '50+', icon: '🃏' },
  { name: 'Baccarat', count: '30+', icon: '💎' },
  { name: 'Poker', count: '25+', icon: '♠️' },
  { name: 'Other Games', count: '20+', icon: '🎰' }
];

const gameRules = [
  {
    game: 'Roulette',
    icon: '🎡',
    description: 'Bet on where the ball will land on the spinning wheel',
    rules: ['Place bets on numbers, colors, or sections', 'Dealer spins the wheel', 'Ball lands on winning number', 'Payouts based on bet type']
  },
  {
    game: 'Blackjack',
    icon: '🃏',
    description: 'Get as close to 21 as possible without going over',
    rules: ['Beat the dealer\'s hand', 'Cards 2-10 worth face value', 'Face cards worth 10', 'Ace worth 1 or 11']
  },
  {
    game: 'Baccarat',
    icon: '💎',
    description: 'Bet on Player, Banker, or Tie to win',
    rules: ['Two hands dealt: Player and Banker', 'Hand closest to 9 wins', 'Third card rules apply', 'Banker bet has 5% commission']
  },
  {
    game: 'Poker',
