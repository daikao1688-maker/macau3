---

<Layout title="Table Games - CasinoPro | Classic Casino Games">  
  <main class="min-h-screen pt-20">
    <!-- Hero Section -->
    <section class="relative py-20 overflow-hidden">
      <!-- Background -->
      <div class="absolute inset-0">
        <img 
          src="https://images.unsplash.com/photo-1511193311914-0346f16efe90?w=1920&h=600&fit=crop&q=80"
          alt="Table Games Background"
          class="absolute inset-0 w-full h-full object-cover opacity-20"
        />
      </div>
      <div class="absolute inset-0 bg-gradient-to-br from-dark-950 via-dark-900 to-secondary-900/20"></div>
      
      <!-- Animated circles -->
      <div class="absolute top-20 left-10 w-72 h-72 bg-secondary-500/10 rounded-full blur-3xl animate-pulse-slow"></div>
      <div class="absolute bottom-20 right-10 w-96 h-96 bg-primary-500/10 rounded-full blur-3xl animate-pulse-slow" style="animation-delay: 1s;"></div>
      
      <div class="container mx-auto px-4 relative z-10">
        <div class="max-w-4xl mx-auto text-center space-y-6">
          <span class="inline-block text-secondary-500 font-bold text-sm uppercase tracking-widest mb-4 px-6 py-2 bg-secondary-500/10 rounded-full border border-secondary-500/30">
            🎲 Classic Casino Experience
          </span>
          
          <h1 class="text-5xl md:text-6xl lg:text-7xl font-display font-black leading-tight">
            <span class="text-gradient glow-text">Premium Table Games</span>
            <span class="block text-white mt-2">Master the Classics</span>
          </h1>
          
          <p class="text-xl md:text-2xl text-gray-300 max-w-3xl mx-auto leading-relaxed">
            Experience authentic casino table games with professional dealers and high-quality graphics
          </p>
          
          <!-- Quick Stats -->
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4 pt-8">
            <div class="card-glass p-4">
              <div class="text-3xl font-display font-black text-secondary-500">150+</div>
              <div class="text-sm text-gray-400">Table Games</div>
            </div>
            <div class="card-glass p-4">
              <div class="text-3xl font-display font-black text-secondary-500">99.7%</div>
              <div class="text-sm text-gray-400">Max RTP</div>
            </div>
            <div class="card-glass p-4">
              <div class="text-3xl font-display font-black text-secondary-500">$1</div>
              <div class="text-sm text-gray-400">Min Bet</div>
            </div>
            <div class="card-glass p-4">
              <div class="text-3xl font-display font-black text-secondary-500">24/7</div>
              <div class="text-sm text-gray-400">Available</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Categories Section -->
    <section class="section-padding bg-dark-900/50">
      <div class="container mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-display font-black text-white mb-4">
            Browse by <span class="text-gradient">Game Type</span>
          </h2>
          <p class="text-gray-400">Choose your favorite table game</p>
        </div>
        
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
          {categories.map(cat => (
            <button class="card-glass p-6 hover:scale-105 transition-all duration-300 group text-center">
              <div class="text-4xl mb-3">{cat.icon}</div>
              <h3 class="text-white font-bold text-sm mb-1 group-hover:text-secondary-500 transition-colors">{cat.name}</h3>
              <p class="text-gray-400 text-xs">{cat.count} games</p>
            </button>
          ))}
        </div>
      </div>
    </section>

    <!-- Filters & Search -->
    <section class="section-padding">
      <div class="container mx-auto">
        <div class="card-glass p-6 mb-8">
          <div class="flex flex-col md:flex-row gap-4">
            <!-- Search -->
            <div class="flex-1">
              <div class="relative">
                <input 
                  type="text" 
                  placeholder="Search table games..."
                  class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 pl-12 text-white placeholder-gray-500 focus:outline-none focus:border-secondary-500 transition-colors"
                />
                <svg class="w-5 h-5 text-gray-500 absolute left-4 top-1/2 transform -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
              </div>
            </div>
            
            <!-- Bet Range Filter -->
            <select class="bg-dark-800 border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-secondary-500 transition-colors cursor-pointer">
              <option value="" class="bg-dark-800 text-white">All Bet Ranges</option>
              <option value="low" class="bg-dark-800 text-white">$1 - $10</option>
              <option value="medium" class="bg-dark-800 text-white">$10 - $100</option>
              <option value="high" class="bg-dark-800 text-white">$100+</option>
            </select>
            
            <!-- Sort -->
            <select class="bg-dark-800 border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-secondary-500 transition-colors cursor-pointer">
              <option value="popular" class="bg-dark-800 text-white">Most Popular</option>
              <option value="rtp" class="bg-dark-800 text-white">Highest RTP</option>
              <option value="new" class="bg-dark-800 text-white">Newest</option>
              <option value="az" class="bg-dark-800 text-white">A-Z</option>
            </select>
          </div>
        </div>

        <!-- Games Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
          {tableGames.map(game => (
            <div class="card-glass overflow-hidden hover:scale-105 transition-all duration-300 group relative">
              {game.hot && (
                <div class="absolute top-0 right-0 bg-gradient-to-l from-accent-red to-transparent px-6 py-1 text-xs font-bold text-white z-30">
                  🔥 HOT
                </div>
              )}
              
              <!-- Game Image -->
              <div class="relative h-48 overflow-hidden">
                <!-- Fallback gradient -->
                <div class="absolute inset-0 bg-gradient-to-br from-secondary-500/30 to-primary-500/30"></div>
                
                <img 
                  src={game.image}
                  alt={game.title}
                  class="absolute inset-0 w-full h-full object-cover z-10 group-hover:scale-110 transition-transform duration-500"
                  loading="lazy"
                />
                
                <!-- Gradient overlay -->
                <div class="absolute inset-0 bg-gradient-to-t from-dark-950 via-dark-950/50 to-transparent z-20"></div>
                
                <!-- Category Badge -->
                <div class="absolute bottom-3 left-3 z-30">
                  <span class="px-3 py-1 bg-secondary-500/90 backdrop-blur-sm text-white text-xs font-bold rounded-full border border-white/20">
                    {game.category}
                  </span>
                </div>
              </div>

              <!-- Game Info -->
              <div class="p-4 space-y-3">
                <div>
                  <h3 class="text-lg font-display font-bold text-white mb-1 group-hover:text-secondary-500 transition-colors">
                    {game.title}
                  </h3>
                  <p class="text-gray-400 text-xs">{game.description}</p>
                </div>

                <!-- Stats -->
                <div class="flex items-center justify-between text-xs">
                  <div class="flex items-center space-x-1">
                    <svg class="w-4 h-4 text-primary-500" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                    <span class="text-white font-bold">{game.rating}</span>
                  </div>
                  <div class="flex items-center space-x-1 text-gray-400">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
                    </svg>
                    <span>{game.players}</span>
                  </div>
                  <div class="text-accent-green font-bold">
                    RTP {game.rtp}
                  </div>
                </div>

                <!-- Betting Range -->
                <div class="flex justify-between items-center pt-3 border-t border-white/10">
                  <div>
                    <div class="text-xs text-gray-400">Min Bet</div>
                    <div class="text-white font-bold">{game.minBet}</div>
                  </div>
                  <div class="text-right">
                    <div class="text-xs text-gray-400">Max Bet</div>
                    <div class="text-secondary-500 font-bold">{game.maxBet}</div>
                  </div>
                </div>

                <!-- Play Button -->
                <button class="w-full bg-gradient-to-r from-secondary-500 to-secondary-600 hover:from-secondary-600 hover:to-secondary-700 text-white font-bold py-3 rounded-lg transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-secondary-500/50 relative overflow-hidden group/btn">
                  <span class="relative z-10">Play Now</span>
                  <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent transform -skew-x-12 -translate-x-full group-hover/btn:translate-x-full transition-transform duration-700"></div>
                </button>
              </div>
            </div>
          ))}
        </div>

        <!-- Load More -->
        <div class="text-center mt-12">
          <button class="btn-primary text-lg px-12 py-4">
            Load More Games
          </button>
          <p class="text-gray-400 text-sm mt-4">Showing 12 of 150+ table games</p>
        </div>
      </div>
    </section>

    <!-- Game Rules Section -->
    <section class="section-padding bg-dark-900/50">
      <div class="container mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-display font-black text-white mb-4">
            How to <span class="text-gradient">Play</span>
          </h2>
          <p class="text-gray-400">Learn the basics of popular table games</p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          {gameRules.map(rule => (
            <div class="card-glass p-6 space-y-4 hover:scale-105 transition-all duration-300">
              <div class="w-16 h-16 bg-gradient-to-br from-secondary-500 to-secondary-600 rounded-2xl flex items-center justify-center mx-auto text-3xl">
                {rule.icon}
              </div>
              
              <h3 class="text-xl font-display font-bold text-white text-center">{rule.game}</h3>
              
              <p class="text-gray-400 text-sm text-center">{rule.description}</p>
              
              <ul class="space-y-2 pt-4 border-t border-white/10">
                {rule.rules.map(item => (
                  <li class="text-xs text-gray-300 flex items-start">
                    <svg class="w-3 h-3 text-secondary-500 mr-2 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section class="section-padding">
      <div class="container mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-display font-black text-white mb-4">
            Why Play <span class="text-gradient">Table Games</span> With Us?
          </h2>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="card-glass p-6 text-center space-y-4 hover:scale-105 transition-all duration-300">
            <div class="w-16 h-16 bg-gradient-to-br from-secondary-500 to-secondary-600 rounded-2xl flex items-center justify-center mx-auto">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
              </svg>
            </div>
            <h3 class="text-xl font-display font-bold text-white">Certified Fair</h3>
            <p class="text-gray-400 text-sm">All games use certified RNG and are independently audited for fairness</p>
          </div>

          <div class="card-glass p-6 text-center space-y-4 hover:scale-105 transition-all duration-300">
            <div class="w-16 h-16 bg-gradient-to-br from-primary-500 to-primary-600 rounded-2xl flex items-center justify-center mx-auto">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
            </div>
            <h3 class="text-xl font-display font-bold text-white">Instant Play</h3>
            <p class="text-gray-400 text-sm">No download required, play directly in your browser on any device</p>
          </div>

          <div class="card-glass p-6 text-center space-y-4 hover:scale-105 transition-all duration-300">
            <div class="w-16 h-16 bg-gradient-to-br from-accent-green to-emerald-600 rounded-2xl flex items-center justify-center mx-auto">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <h3 class="text-xl font-display font-bold text-white">High RTP</h3>
            <p class="text-gray-400 text-sm">Industry-leading return to player rates up to 99.7%</p>
          </div>

          <div class="card-glass p-6 text-center space-y-4 hover:scale-105 transition-all duration-300">
            <div class="w-16 h-16 bg-gradient-to-br from-accent-pink to-accent-red rounded-2xl flex items-center justify-center mx-auto">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"/>
              </svg>
            </div>
            <h3 class="text-xl font-display font-bold text-white">Flexible Limits</h3>
            <p class="text-gray-400 text-sm">Wide betting range from $1 to $15,000 per hand</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Strategy Tips -->
    <section class="section-padding bg-dark-900/50">
      <div class="container mx-auto">
        <div class="card-glass p-8">
          <h2 class="text-2xl md:text-3xl font-display font-black text-white mb-6 text-center">
            <span class="text-gradient">Pro Tips</span> & Strategies
          </h2>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
            <div class="space-y-4">
              <div class="flex items-start space-x-3">
                <svg class="w-6 h-6 text-secondary-500 flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
