---
import { withBase } from '../utils/paths';
import Layout from '../layouts/Layout.astro';

const sections = [
  { id: 'introduction', title: 'Introduction', icon: '📋' },
  { id: 'definitions', title: 'Definitions', icon: '📖' },
  { id: 'account', title: 'Account Registration', icon: '👤' },
  { id: 'deposits', title: 'Deposits & Withdrawals', icon: '💳' },
  { id: 'bonuses', title: 'Bonuses & Promotions', icon: '🎁' },
  { id: 'gameplay', title: 'Gameplay Rules', icon: '🎮' },
  { id: 'responsible', title: 'Responsible Gaming', icon: '🛡️' },
  { id: 'privacy', title: 'Privacy & Security', icon: '🔒' },
  { id: 'intellectual', title: 'Intellectual Property', icon: '©️' },
  { id: 'liability', title: 'Liability & Disputes', icon: '⚖️' },
  { id: 'termination', title: 'Account Termination', icon: '🚫' },
  { id: 'general', title: 'General Provisions', icon: '📄' }
];

const lastUpdated = 'January 1, 2026';
---

<Layout title="Terms & Conditions - CasinoPro">  
  <main class="min-h-screen pt-20">
    <!-- Hero Section -->
    <section class="relative py-20 overflow-hidden">
      <!-- Background -->
      <div class="absolute inset-0">
        <img 
          src="https://images.unsplash.com/photo-1450101499163-c8848c66ca85?w=1920&h=600&fit=crop&q=80"
          alt="Terms & Conditions Background"
          class="absolute inset-0 w-full h-full object-cover opacity-10"
          loading="lazy"
        />
      </div>
      <div class="absolute inset-0 bg-gradient-to-br from-dark-950 via-dark-900 to-secondary-900/20"></div>
      
      <!-- Animated circles -->
      <div class="absolute top-20 left-10 w-72 h-72 bg-secondary-500/10 rounded-full blur-3xl animate-pulse-slow"></div>
      <div class="absolute bottom-20 right-10 w-96 h-96 bg-primary-500/10 rounded-full blur-3xl animate-pulse-slow" style="animation-delay: 1s;"></div>
      
      <div class="container mx-auto px-4 relative z-10">
        <div class="max-w-4xl mx-auto text-center space-y-6">
          <span class="inline-block text-secondary-500 font-bold text-sm uppercase tracking-widest mb-4 px-6 py-2 bg-secondary-500/10 rounded-full border border-secondary-500/30">
            📋 Legal Agreement
          </span>
          
          <h1 class="text-5xl md:text-6xl lg:text-7xl font-display font-black leading-tight">
            <span class="text-gradient glow-text">Terms & Conditions</span>
          </h1>
          
          <p class="text-xl md:text-2xl text-gray-300 max-w-3xl mx-auto leading-relaxed">
            Please read these terms carefully before using our services
          </p>
          
          <div class="card-glass p-4 max-w-md mx-auto">
            <div class="text-sm text-gray-400">
              Last Updated: <span class="text-white font-semibold">{lastUpdated}</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Quick Navigation -->
    <section class="section-padding bg-dark-900/50">
      <div class="container mx-auto">
        <div class="text-center mb-8">
          <h2 class="text-2xl md:text-3xl font-display font-black text-white mb-4">
            Quick <span class="text-gradient">Navigation</span>
          </h2>
          <p class="text-gray-400">Jump to any section</p>
        </div>
        
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 max-w-6xl mx-auto">
          {sections.map(section => (
            <a 
              href={`#${section.id}`}
              class="card-glass p-4 hover:scale-105 transition-all duration-300 text-center space-y-2 group"
            >
              <div class="text-3xl">{section.icon}</div>
              <div class="text-sm font-bold text-white group-hover:text-secondary-500 transition-colors">
                {section.title}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Terms Content -->
    <section class="section-padding">
      <div class="container mx-auto">
        <div class="max-w-4xl mx-auto space-y-12">
          
          <!-- Introduction -->
          <div id="introduction" class="card-glass p-8 scroll-mt-24">
            <div class="flex items-center space-x-4 mb-6">
              <div class="w-14 h-14 bg-gradient-to-br from-primary-500 to-yellow-600 rounded-xl flex items-center justify-center text-2xl">
                📋
              </div>
              <h2 class="text-3xl font-display font-black text-white">1. Introduction</h2>
            </div>
            
            <div class="space-y-4 text-gray-300 leading-relaxed">
              <p>
                Welcome to CasinoPro ("we", "us", "our", or "the Company"). These Terms and Conditions ("Terms") govern your use of our website, mobile applications, and services (collectively, the "Services").
              </p>
              <p>
                By creating an account, accessing, or using our Services, you agree to be bound by these Terms, our Privacy Policy, and all applicable laws and regulations. If you do not agree with any part of these Terms, you must not use our Services.
              </p>
              <p>
                We reserve the right to modify these Terms at any time. Changes will be effective immediately upon posting on our website. Your continued use of the Services after any changes constitutes acceptance of the new Terms.
              </p>
              <div class="bg-secondary-500/10 border-l-4 border-secondary-500 p-4 rounded">
                <p class="text-secondary-500 font-semibold">Important Notice:</p>
                <p class="text-sm mt-2">You must be at least 18 years old (or the legal age of majority in your jurisdiction) to use our Services. Gambling may be illegal in your jurisdiction. It is your responsibility to ensure compliance with local laws.</p>
              </div>
            </div>
          </div>

          <!-- Definitions -->
          <div id="definitions" class="card-glass p-8 scroll-mt-24">
            <div class="flex items-center space-x-4 mb-6">
              <div class="w-14 h-14 bg-gradient-to-br from-secondary-500 to-purple-600 rounded-xl flex items-center justify-center text-2xl">
                📖
              </div>
              <h2 class="text-3xl font-display font-black text-white">2. Definitions</h2>
            </div>
            
            <div class="space-y-4 text-gray-300 leading-relaxed">
              <p>In these Terms, unless the context requires otherwise:</p>
              <ul class="space-y-3 ml-6">
                <li class="flex items-start space-x-3">
                  <span class="text-secondary-500 font-bold mt-1">•</span>
                  <span><strong class="text-white">"Account"</strong> means the personal account created by you to access our Services.</span>
                </li>
                <li class="flex items-start space-x-3">
                  <span class="text-secondary-500 font-bold mt-1">•</span>
                  <span><strong class="text-white">"Player" or "You"</strong> means any person who creates an account and uses our Services.</span>
                </li>
                <li class="flex items-start space-x-3">
                  <span class="text-secondary-500 font-bold mt-1">•</span>
                  <span><strong class="text-white">"Bonus"</strong> means any promotional offer, free spins, or bonus funds provided by us.</span>
                </li>
                <li class="flex items-start space-x-3">
                  <span class="text-secondary-500 font-bold mt-1">•</span>
                  <span><strong class="text-white">"Deposit"</strong> means funds transferred by you to your Account for the purpose of gambling.</span>
                </li>
                <li class="flex items-start space-x-3">
                  <span class="text-secondary-500 font-bold mt-1">•</span>
                  <span><strong class="text-white">"Withdrawal"</strong> means funds transferred from your Account to your designated payment method.</span>
                </li>
                <li class="flex items-start space-x-3">
                  <span class="text-secondary-500 font-bold mt-1">•</span>
                  <span><strong class="text-white">"Game"</strong> means any casino game, slot, table game, or live dealer game available on our platform.</span>
                </li>
                <li class="flex items-start space-x-3">
                  <span class="text-secondary-500 font-bold mt-1">•</span>
                  <span><strong class="text-white">"Wagering Requirements"</strong> means the number of times you must wager bonus funds before withdrawal.</span>
                </li>
              </ul>
            </div>
          </div>

          <!-- Account Registration -->
          <div id="account" class="card-glass p-8 scroll-mt-24">
            <div class="flex items-center space-x-4 mb-6">
              <div class="w-14 h-14 bg-gradient-to-br from-accent-green to-emerald-600 rounded-xl flex items-center justify-center text-2xl">
                👤
              </div>
              <h2 class="text-3xl font-display font-black text-white">3. Account Registration</h2>
            </div>
            
            <div class="space-y-4 text-gray-300 leading-relaxed">
              <h3 class="text-xl font-bold text-white">3.1 Eligibility</h3>
              <p>To create an account, you must:</p>
              <ul class="space-y-2 ml-6">
                <li class="flex items-start space-x-3">
                  <span class="text-accent-green font-bold mt-1">✓</span>
                  <span>Be at least 18 years old or the legal age of majority in your jurisdiction</span>
                </li>
                <li class="flex items-start space-x-3">
                  <span class="text-accent-green font-bold mt-1">✓</span>
                  <span>Reside in a jurisdiction where online gambling is legal</span>
                </li>
                <li class="flex items-start space-x-3">
                  <span class="text-accent-green font-bold mt-1">✓</span>
                  <span>Provide accurate, current, and complete information</span>
                </li>
                <li class="flex items-start space-x-3">
                  <span class="text-accent-green font-bold mt-1">✓</span>
                  <span>Not be self-excluded or prohibited from gambling</span>
                </li>
                <li class="flex items-start space-x-3">
                  <span class="text-accent-green font-bold mt-1">✓</span>
                  <span>Act on your own behalf and not on behalf of any third party</span>
                </li>
              </ul>

              <h3 class="text-xl font-bold text-white mt-6">3.2 Account Restrictions</h3>
              <ul class="space-y-2 ml-6">
                <li class="flex items-start space-x-3">
                  <span class="text-accent-red font-bold mt-1">✗</span>
                  <span>You may only have ONE account. Multiple accounts will be closed and funds forfeited.</span>
                </li>
                <li class="flex items-start space-x-3">
                  <span class="text-accent-red font-bold mt-1">✗</span>
                  <span>You cannot transfer, sell, or share your account with anyone.</span>
                </li>
                <li class="flex items-start space-x-3">
                  <span class="text-accent-red font-bold mt-1">✗</span>
                  <span>You are responsible for maintaining the confidentiality of your login credentials.</span>
                </li>
              </ul>

              <h3 class="text-xl font-bold text-white mt-6">3.3 Verification</h3>
              <p>
                We require identity verification (KYC - Know Your Customer) before processing withdrawals. You must provide valid identification documents, proof of address, and proof of payment method. Failure to provide requested documents may result in account suspension and withdrawal delays.
              </p>
            </div>
          </div>

          <!-- Deposits & Withdrawals -->
          <div id="deposits" class="card-glass p-8 scroll-mt-24">
            <div class="flex items-center space-x-4 mb-6">
              <div class="w-14 h-14 bg-gradient-to-br from-accent-blue to-blue-600 rounded-xl flex items-center justify-center text-2xl">
                💳
              </div>
              <h2 class="text-3xl font-display font-black text-white">4. Deposits & Withdrawals</h2>
            </div>
            
            <div class="space-y-4 text-gray-300 leading-relaxed">
              <h3 class="text-xl font-bold text-white">4.1 Deposits</h3>
              <ul class="space-y-2 ml-6">
                <li>• Minimum deposit: $10 (may vary by payment method)</li>
                <li>• All deposits are final and non-refundable</li>
                <li>• You must use a payment method in your own name</li>
                <li>• We do not charge deposit fees, but your payment provider may</li>
                <li>• Deposits are typically instant, but may take up to 24 hours</li>
              </ul>

              <h3 class="text-xl font-bold text-white mt-6">4.2 Withdrawals</h3>
              <ul class="space-y-2 ml-6">
                <li>• Minimum withdrawal: $20</li>
                <li>• Maximum withdrawal: $5,000 per day (higher for VIP players)</li>
                <li>• Withdrawals must be made to the same payment method used for deposits</li>
                <li>• Processing time: 24-48 hours after verification</li>
                <li>• You must wager your deposit at least once before withdrawal (AML requirement)</li>
                <li>• Bonus funds must meet wagering requirements before withdrawal</li>
              </ul>

              <h3 class="text-xl font-bold text-white mt-6">4.3 Fees</h3>
              <p>
                We do not charge fees for deposits or withdrawals. However, your payment provider, bank, or cryptocurrency network may charge their own fees. Currency conversion fees may apply for transactions in currencies other than your account currency.
              </p>

              <div class="bg-primary-500/10 border-l-4 border-primary-500 p-4 rounded mt-4">
                <p class="text-primary-500 font-semibold">Anti-Money Laundering (AML):</p>
                <p class="text-sm mt-2">We comply with AML regulations. Suspicious transactions will be reported to relevant authorities. You may be required to provide source of funds documentation.</p>
              </div>
            </div>
          </div>

          <!-- Bonuses & Promotions -->
          <div id="bonuses" class="card-glass p-8 scroll-mt-24">
            <div class="flex items-center space-x-4 mb-6">
              <div class="w-14 h-14 bg-gradient-to-br from-accent-pink to-accent-red rounded-xl flex items-center justify-center text-2xl">
                🎁
              </div>
              <h2 class="text-3xl font-display font-black text-white">5. Bonuses & Promotions</h2>
            </div>
            
            <div class="space-y-4 text-gray-300 leading-relaxed">
              <h3 class="text-xl font-bold text-white">5.1 General Bonus Terms</h3>
              <ul class="space-y-2 ml-6">
                <li>• All bonuses are subject to wagering requirements (typically 35x)</li>
                <li>• Maximum bet with bonus funds: $5 per spin/hand</li>
                <li>• Bonuses expire after 30 days if wagering is not completed</li>
                <li>• Only one bonus can be active at a time</li>
                <li>• We reserve the right to void bonuses if terms are breached</li>
                <li>• Bonus abuse will result in forfeiture of bonus and winnings</li>
              </ul>

              <h3 class="text-xl font-bold text-white mt-6">5.2 Game Contributions</h3>
              <p>Different games contribute differently to wagering requirements:</p>
              <ul class="space-y-2 ml-6">
                <li>• Slots: 100%</li>
                <li>• Table Games: 10-20%</li>
                <li>• Live Casino: 10%</li>
                <li>• Video Poker: 10%</li>
                <li>• Some games may be excluded entirely</li>
              </ul>

              <h3 class="text-xl font-bold text-white mt-6">5.3 Withdrawal Restrictions</h3>
              <p>
                You cannot withdraw bonus funds until wagering requirements are met. When you request a withdrawal with an active bonus, the bonus amount will be deducted from your balance. Maximum withdrawal from no-deposit bonuses is typically $100.
              </p>
            </div>
          </div>

          <!-- Gameplay Rules -->
          <div id="gameplay" class="card-glass p-8 scroll-mt-24">
            <div class="flex items-center space-x-4 mb-6">
              <div class="w-14 h-14 bg-gradient-to-br from-orange-500 to-red-600 rounded-xl flex items-center justify-center text-2xl">
                🎮
              </div>
              <h2 class="text-3xl font-display font-black text-white">6. Gameplay Rules</h2>
            </div>
            
            <div class="space-y-4 text-gray-300 leading-relaxed">
              <h3 class="text-xl font-bold text-white">6.1 Fair Play</h3>
              <p>All games use certified Random Number Generators (RNG) to ensure fair and random outcomes. We prohibit:</p>
              <ul class="space-y-2 ml-6">
                <li>• Use of bots, scripts, or automated software</li>
                <li>• Collusion with other players</li>
                <li>• Exploitation of software errors or bugs</li>
                <li>• Any form of cheating or fraudulent activity</li>
                <li>• Irregular playing patterns designed to abuse bonuses</li>
              </ul>

              <h3 class="text-xl font-bold text-white mt-6">6.2 Game Malfunctions</h3>
              <p>
                In the event of a game malfunction, all affected bets and payouts are void. We will investigate and resolve disputes fairly. If a game disconnects during play, your bet remains valid and will be settled according to the game outcome.
              </p>

              <h3 class="text-xl font-bold text-white mt-6">6.3 Betting Limits</h3>
              <p>
                Each game has minimum and maximum betting limits. We reserve the right to adjust limits at any time. VIP players may have access to higher limits.
              </p>

              <h3 class="text-xl font-bold text-white mt-6">6.4 Winnings</h3>
              <p>
                All winnings are credited to your account balance immediately. Large wins may be subject to additional verification. Progressive jackpot wins are paid according to the game's specific rules.
              </p>
            </div>
          </div>

          <!-- Responsible Gaming -->
          <div id="responsible" class="card-glass p-8 scroll-mt-24">
            <div class="flex items-center space-x-4 mb-6">
              <div class="w-14 h-14 bg-gradient-to-br from-primary-500 to-yellow-600 rounded-xl flex items-center justify-center text-2xl">
                🛡️
              </div>
              <h2 class="text-3xl font-display font-black text-white">7. Responsible Gaming</h2>
            </div>
            
            <div class="space-y-4 text-gray-300 leading-relaxed">
              <p>
                We are committed to promoting responsible gambling. We provide tools to help you stay in control:
              </p>
              <ul class="space-y-2 ml-6">
                <li>• Deposit limits (daily, weekly, monthly)</li>
                <li>• Loss limits</li>
                <li>• Session time limits</li>
                <li>• Reality checks</li>
                <li>• Take a break (24 hours to 6 months)</li>
                <li>• Self-exclusion (6 months to permanent)</li>
              </ul>

              <p class="mt-4">
                If you believe you have a gambling problem, please contact GamCare (0808 8020 133) or visit our <a href={withBase('/responsible-gaming')} class="text-secondary-500 hover:text-secondary-400 underline">Responsible Gaming</a> page for more resources.
              </p>

              <div class="bg-accent-red/10 border-l-4 border-accent-red p-4 rounded mt-4">
                <p class="text-accent-red font-semibold">Self-Exclusion:</p>
                <p class="text-sm mt-2">Once you self-exclude, you cannot reopen your account during the exclusion period. For UK players, we recommend using GamStop for multi-operator exclusion.</p>
              </div>
            </div>
          </div>

          <!-- Privacy & Security -->
          <div id="privacy" class="card-glass p-8 scroll-mt-24">
            <div class="flex items-center space-x-4 mb-6">
              <div class="w-14 h-14 bg-gradient-to-br from-secondary-500 to-purple-600 rounded-xl flex items-center justify-center text-2xl">
                🔒
              </div>
              <h2 class="text-3xl font-display font-black text-white">8. Privacy & Security</h2>
            </div>
            
            <div class="space-y-4 text-gray-300 leading-relaxed">
              <h3 class="text-xl font-bold text-white">8.1 Data Protection</h3>
              <p>
                We collect, process, and store your personal data in accordance with our <a href="#" class="text-secondary-500 hover:text-secondary-400 underline">Privacy Policy</a> and applicable data protection laws (GDPR, etc.). Your data is encrypted using 256-bit SSL technology.
              </p>

              <h3 class="text-xl font-bold text-white mt-6">8.2 Information We Collect</h3>
              <ul class="space-y-2 ml-6">
                <li>• Personal information (name, address, date of birth)</li>
                <li>• Contact information (email, phone number)</li>
                <li>• Payment information (encrypted and not stored in full)</li>
                <li>• Gaming activity and transaction history</li>
                <li>• Device and browser information</li>
                <li>• IP address and location data</li>
              </ul>

              <h3 class="text-xl font-bold text-white mt-6">8.3 How We Use Your Data</h3>
              <ul class="space-y-2 ml-6">
                <li>• To provide and improve our Services</li>
                <li>• To verify your identity and prevent fraud</li>
                <li>• To process transactions and payments</li>
                <li>• To comply with legal and regulatory requirements</li>
                <li>• To send promotional communications (with your consent)</li>
                <li>• To detect and prevent problem gambling</li>
              </ul>

              <h3 class="text-xl font-bold text-white mt-6">8.4 Your Rights</h3>
              <p>You have the right to:</p>
              <ul class="space-y-2 ml-6">
                <li>• Access your personal data</li>
                <li>• Correct inaccurate data</li>
                <li>• Request deletion of your data (subject to legal obligations)</li>
                <li>• Object to processing of your data</li>
                <li>• Withdraw consent for marketing communications</li>
              </ul>
            </div>
          </div>

          <!-- Intellectual Property -->
          <div id="intellectual" class="card-glass p-8 scroll-mt-24">
            <div class="flex items-center space-x-4 mb-6">
              <div class="w-14 h-14 bg-gradient-to-br from-accent-green to-emerald-600 rounded-xl flex items-center justify-center text-2xl">
                ©️
              </div>
              <h2 class="text-3xl font-display font-black text-white">9. Intellectual Property</h2>
            </div>
            
            <div class="space-y-4 text-gray-300 leading-relaxed">
              <p>
                All content on our website, including but not limited to text, graphics, logos, images, software, and games, is the property of CasinoPro or our licensors and is protected by copyright, trademark, and other intellectual property laws.
              </p>

              <h3 class="text-xl font-bold text-white mt-6">9.1 Restrictions</h3>
              <p>You may not:</p>
              <ul class="space-y-2 ml-6">
                <li>• Copy, reproduce, or distribute any content without permission</li>
                <li>• Modify, reverse engineer, or decompile our software</li>
                <li>• Use our trademarks or branding without authorization</li>
                <li>• Create derivative works based on our content</li>
                <li>• Frame or mirror any part of our website</li>
              </ul>

              <h3 class="text-xl font-bold text-white mt-6">9.2 License</h3>
              <p>
                We grant you a limited, non-exclusive, non-transferable license to access and use our Services for personal, non-commercial purposes only. This license terminates if you breach these Terms.
              </p>
            </div>
          </div>

          <!-- Liability & Disputes -->
          <div id="liability" class="card-glass p-8 scroll-mt-24">
            <div class="flex items-center space-x-4 mb-6">
              <div class="w-14 h-14 bg-gradient-to-br from-accent-blue to-blue-600 rounded-xl flex items-center justify-center text-2xl">
                ⚖️
              </div>
              <h2 class="text-3xl font-display font-black text-white">10. Liability & Disputes</h2>
            </div>
            
            <div class="space-y-4 text-gray-300 leading-relaxed">
              <h3 class="text-xl font-bold text-white">10.1 Limitation of Liability</h3>
              <p>
                To the maximum extent permitted by law, we are not liable for any indirect, incidental, special, consequential, or punitive damages, including loss of profits, data, or goodwill, arising from your use of our Services.
              </p>

              <h3 class="text-xl font-bold text-white mt-6">10.2 Disclaimer</h3>
              <p>
                Our Services are provided "as is" without warranties of any kind, either express or implied. We do not guarantee that our Services will be uninterrupted, error-free, or secure.
              </p>

              <h3 class="text-xl font-bold text-white mt-6">10.3 Dispute Resolution</h3>
              <p>
                If you have a complaint, please contact our customer support team first. We will attempt to resolve disputes amicably within 30 days. If unresolved, you may refer the matter to our Alternative Dispute Resolution (ADR) provider or the relevant regulatory authority.
              </p>

              <h3 class="text-xl font-bold text-white mt-6">10.4 Governing Law</h3>
              <p>
                These Terms are governed by the laws of Malta. Any disputes will be subject to the exclusive jurisdiction of the courts of Malta.
              </p>
            </div>
          </div>

          <!-- Account Termination -->
          <div id="termination" class="card-glass p-8 scroll-mt-24">
            <div class="flex items-center space-x-4 mb-6">
              <div class="w-14 h-14 bg-gradient-to-br from-accent-pink to-accent-red rounded-xl flex items-center justify-center text-2xl">
                🚫
              </div>
              <h2 class="text-3xl font-display font-black text-white">11. Account Termination</h2>
            </div>
            
            <div class="space-y-4 text-gray-300 leading-relaxed">
              <h3 class="text-xl font-bold text-white">11.1 Termination by You</h3>
              <p>
                You may close your account at any time by contacting customer support. You must withdraw any remaining balance before closure. Self-excluded accounts cannot be reopened during the exclusion period.
              </p>

              <h3 class="text-xl font-bold text-white mt-6">11.2 Termination by Us</h3>
