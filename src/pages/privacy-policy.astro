---
import { withBase } from '../utils/paths';
import Layout from '../layouts/Layout.astro';

const sections = [
  { id: 'introduction', title: 'Introduction', icon: '📋' },
  { id: 'controller', title: 'Data Controller', icon: '🏢' },
  { id: 'collection', title: 'Information We Collect', icon: '📊' },
  { id: 'usage', title: 'How We Use Your Data', icon: '🔄' },
  { id: 'legal', title: 'Legal Basis', icon: '⚖️' },
  { id: 'sharing', title: 'Data Sharing', icon: '🤝' },
  { id: 'security', title: 'Data Security', icon: '🔒' },
  { id: 'retention', title: 'Data Retention', icon: '📅' },
  { id: 'rights', title: 'Your Rights', icon: '✋' },
  { id: 'cookies', title: 'Cookies', icon: '🍪' },
  { id: 'international', title: 'International Transfers', icon: '🌍' },
  { id: 'children', title: 'Children\'s Privacy', icon: '👶' },
  { id: 'changes', title: 'Policy Changes', icon: '📝' },
  { id: 'contact', title: 'Contact Us', icon: '📧' }
];

const dataTypes = [
  {
    category: 'Personal Information',
    icon: '👤',
    color: 'from-primary-500 to-yellow-600',
    items: [
      'Full name',
      'Date of birth',
      'Gender',
      'Nationality',
      'Address (residential)',
      'Government-issued ID number'
    ]
  },
  {
    category: 'Contact Information',
    icon: '📞',
    color: 'from-secondary-500 to-purple-600',
    items: [
      'Email address',
      'Phone number',
      'Postal address',
      'Preferred language'
    ]
  },
  {
    category: 'Financial Information',
    icon: '💳',
    color: 'from-accent-green to-emerald-600',
    items: [
      'Payment method details',
      'Transaction history',
      'Deposit and withdrawal records',
      'Bonus and promotion usage'
    ]
  },
  {
    category: 'Gaming Activity',
    icon: '🎮',
    color: 'from-accent-blue to-blue-600',
    items: [
      'Games played',
      'Betting history',
      'Win/loss records',
      'Session duration',
      'Gameplay patterns'
    ]
  },
  {
    category: 'Technical Data',
    icon: '💻',
    color: 'from-accent-pink to-accent-red',
    items: [
      'IP address',
      'Device information',
      'Browser type and version',
      'Operating system',
      'Location data',
      'Cookies and tracking data'
    ]
  },
  {
    category: 'Verification Documents',
    icon: '📄',
    color: 'from-orange-500 to-red-600',
    items: [
      'Passport or ID card',
      'Proof of address',
      'Proof of payment method',
      'Source of funds documentation'
    ]
  }
];

const yourRights = [
  {
    right: 'Right to Access',
    icon: '👁️',
    description: 'Request a copy of all personal data we hold about you',
    action: 'Request Data'
  },
  {
    right: 'Right to Rectification',
    icon: '✏️',
    description: 'Correct any inaccurate or incomplete personal data',
    action: 'Update Data'
  },
  {
    right: 'Right to Erasure',
    icon: '🗑️',
    description: 'Request deletion of your personal data (subject to legal obligations)',
    action: 'Delete Data'
  },
  {
    right: 'Right to Restriction',
    icon: '⏸️',
    description: 'Restrict processing of your personal data in certain circumstances',
    action: 'Restrict Processing'
  },
  {
    right: 'Right to Portability',
    icon: '📦',
    description: 'Receive your data in a structured, machine-readable format',
    action: 'Export Data'
  },
  {
    right: 'Right to Object',
    icon: '🚫',
    description: 'Object to processing of your data for marketing or other purposes',
    action: 'Object to Processing'
  },
  {
    right: 'Right to Withdraw Consent',
    icon: '↩️',
    description: 'Withdraw consent for data processing at any time',
    action: 'Withdraw Consent'
  },
  {
    right: 'Right to Complain',
    icon: '📢',
    description: 'Lodge a complaint with your local data protection authority',
    action: 'File Complaint'
  }
];

const securityMeasures = [
  {
    measure: 'SSL Encryption',
    icon: '🔐',
    description: '256-bit SSL encryption for all data transmission'
  },
  {
    measure: 'Secure Servers',
    icon: '🖥️',
    description: 'Data stored on secure servers with restricted access'
  },
  {
    measure: 'Firewall Protection',
    icon: '🛡️',
    description: 'Advanced firewall systems to prevent unauthorized access'
  },
  {
    measure: 'Regular Audits',
    icon: '🔍',
    description: 'Regular security audits and vulnerability assessments'
  },
  {
    measure: 'Access Controls',
    icon: '🔑',
    description: 'Strict access controls and authentication protocols'
  },
  {
    measure: 'Data Backup',
    icon: '💾',
    description: 'Regular encrypted backups to prevent data loss'
  }
];

const lastUpdated = 'January 1, 2026';
---

<Layout title="Privacy Policy - CasinoPro">  
  <main class="min-h-screen pt-20">
    <!-- Hero Section -->
    <section class="relative py-20 overflow-hidden">
      <!-- Background -->
      <div class="absolute inset-0">
        <img 
          src="https://images.unsplash.com/photo-1563986768609-322da13575f3?w=1920&h=600&fit=crop&q=80"
          alt="Privacy Policy Background"
          class="absolute inset-0 w-full h-full object-cover opacity-10"
          loading="lazy"
        />
      </div>
      <div class="absolute inset-0 bg-gradient-to-br from-dark-950 via-dark-900 to-secondary-900/20"></div>
      
      <!-- Animated circles -->
      <div class="absolute top-20 left-10 w-72 h-72 bg-secondary-500/10 rounded-full blur-3xl animate-pulse-slow"></div>
      <div class="absolute bottom-20 right-10 w-96 h-96 bg-primary-500/10 rounded-full blur-3xl animate-pulse-slow" style="animation-delay: 1s;"></div>
      
      <div class="container mx-auto px-4 relative z-10">
        <div class="max-w-4xl mx-auto text-center space-y-6">
          <span class="inline-block text-secondary-500 font-bold text-sm uppercase tracking-widest mb-4 px-6 py-2 bg-secondary-500/10 rounded-full border border-secondary-500/30">
            🔒 Your Privacy Matters
          </span>
          
          <h1 class="text-5xl md:text-6xl lg:text-7xl font-display font-black leading-tight">
            <span class="text-gradient glow-text">Privacy Policy</span>
          </h1>
          
          <p class="text-xl md:text-2xl text-gray-300 max-w-3xl mx-auto leading-relaxed">
            We are committed to protecting your personal data and respecting your privacy
          </p>
          
          <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
            <div class="card-glass p-4">
              <div class="text-sm text-gray-400">
                Last Updated: <span class="text-white font-semibold">{lastUpdated}</span>
              </div>
            </div>
            <div class="card-glass p-4">
              <div class="text-sm text-gray-400">
                <span class="text-accent-green font-semibold">GDPR Compliant</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Quick Navigation -->
    <section class="section-padding bg-dark-900/50">
      <div class="container mx-auto">
        <div class="text-center mb-8">
          <h2 class="text-2xl md:text-3xl font-display font-black text-white mb-4">
            Quick <span class="text-gradient">Navigation</span>
          </h2>
          <p class="text-gray-400">Jump to any section</p>
        </div>
        
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-7 gap-4 max-w-7xl mx-auto">
          {sections.map(section => (
            <a 
              href={`#${section.id}`}
              class="card-glass p-4 hover:scale-105 transition-all duration-300 text-center space-y-2 group"
            >
              <div class="text-3xl">{section.icon}</div>
              <div class="text-xs font-bold text-white group-hover:text-secondary-500 transition-colors">
                {section.title}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Privacy Content -->
    <section class="section-padding">
      <div class="container mx-auto">
        <div class="max-w-4xl mx-auto space-y-12">
          
          <!-- Introduction -->
          <div id="introduction" class="card-glass p-8 scroll-mt-24">
            <div class="flex items-center space-x-4 mb-6">
              <div class="w-14 h-14 bg-gradient-to-br from-primary-500 to-yellow-600 rounded-xl flex items-center justify-center text-2xl">
                📋
              </div>
              <h2 class="text-3xl font-display font-black text-white">1. Introduction</h2>
            </div>
            
            <div class="space-y-4 text-gray-300 leading-relaxed">
              <p>
                CasinoPro ("we", "us", "our", or "the Company") is committed to protecting and respecting your privacy. This Privacy Policy explains how we collect, use, disclose, and safeguard your personal information when you use our website, mobile applications, and services (collectively, the "Services").
              </p>
              <p>
                This policy applies to all users of our Services and should be read in conjunction with our <a href={withBase('/terms-and-conditions')} class="text-secondary-500 hover:text-secondary-400 underline">Terms and Conditions</a>.
              </p>
              <p>
                We are committed to compliance with the General Data Protection Regulation (GDPR), the UK Data Protection Act 2018, and other applicable data protection laws.
              </p>
              <div class="bg-secondary-500/10 border-l-4 border-secondary-500 p-4 rounded">
                <p class="text-secondary-500 font-semibold">Important:</p>
                <p class="text-sm mt-2">By using our Services, you consent to the collection and use of your personal data as described in this Privacy Policy. If you do not agree, please do not use our Services.</p>
              </div>
            </div>
          </div>

          <!-- Data Controller -->
          <div id="controller" class="card-glass p-8 scroll-mt-24">
            <div class="flex items-center space-x-4 mb-6">
              <div class="w-14 h-14 bg-gradient-to-br from-secondary-500 to-purple-600 rounded-xl flex items-center justify-center text-2xl">
                🏢
              </div>
              <h2 class="text-3xl font-display font-black text-white">2. Data Controller</h2>
            </div>
            
            <div class="space-y-4 text-gray-300 leading-relaxed">
              <p>
                CasinoPro is the data controller responsible for your personal data. Our details are:
              </p>
              <div class="card-glass p-6 bg-white/5">
                <ul class="space-y-2">
                  <li><strong class="text-white">Company Name:</strong> CasinoPro Limited</li>
                  <li><strong class="text-white">Registration Number:</strong> C12345</li>
                  <li><strong class="text-white">Registered Address:</strong> Level 3, Portomaso Business Tower, St. Julians STJ 4011, Malta</li>
                  <li><strong class="text-white">Email:</strong> <a href="mailto:privacy@casinopro.com" class="text-secondary-500 hover:text-secondary-400">privacy@casinopro.com</a></li>
                  <li><strong class="text-white">Data Protection Officer:</strong> dpo@casinopro.com</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Information We Collect -->
          <div id="collection" class="card-glass p-8 scroll-mt-24">
            <div class="flex items-center space-x-4 mb-6">
              <div class="w-14 h-14 bg-gradient-to-br from-accent-green to-emerald-600 rounded-xl flex items-center justify-center text-2xl">
                📊
              </div>
              <h2 class="text-3xl font-display font-black text-white">3. Information We Collect</h2>
            </div>
            
            <div class="space-y-6 text-gray-300 leading-relaxed">
              <p>We collect various types of information to provide and improve our Services:</p>
              
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {dataTypes.map(type => (
                  <div class="card-glass p-6 bg-white/5">
                    <div class="flex items-center space-x-3 mb-4">
                      <div class={`w-12 h-12 bg-gradient-to-br ${type.color} rounded-xl flex items-center justify-center text-2xl`}>
                        {type.icon}
                      </div>
                      <h3 class="text-lg font-bold text-white">{type.category}</h3>
                    </div>
                    <ul class="space-y-2">
                      {type.items.map(item => (
                        <li class="flex items-start space-x-2 text-sm">
                          <span class="text-accent-green mt-1">•</span>
                          <span>{item}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- How We Use Your Data -->
          <div id="usage" class="card-glass p-8 scroll-mt-24">
            <div class="flex items-center space-x-4 mb-6">
              <div class="w-14 h-14 bg-gradient-to-br from-accent-blue to-blue-600 rounded-xl flex items-center justify-center text-2xl">
                🔄
              </div>
              <h2 class="text-3xl font-display font-black text-white">4. How We Use Your Data</h2>
            </div>
            
            <div class="space-y-4 text-gray-300 leading-relaxed">
              <p>We use your personal data for the following purposes:</p>
              
              <div class="space-y-4">
                <div class="card-glass p-4 bg-white/5">
                  <h4 class="text-white font-bold mb-2">🎮 Service Provision</h4>
                  <ul class="space-y-1 text-sm ml-4">
                    <li>• Create and manage your account</li>
                    <li>• Process deposits and withdrawals</li>
                    <li>• Provide access to games and features</li>
                    <li>• Process bets and pay out winnings</li>
                  </ul>
                </div>

                <div class="card-glass p-4 bg-white/5">
                  <h4 class="text-white font-bold mb-2">✅ Verification & Compliance</h4>
                  <ul class="space-y-1 text-sm ml-4">
                    <li>• Verify your identity and age (KYC)</li>
                    <li>• Comply with legal and regulatory requirements</li>
                    <li>• Prevent fraud, money laundering, and illegal activities</li>
                    <li>• Detect and prevent problem gambling</li>
                  </ul>
                </div>

                <div class="card-glass p-4 bg-white/5">
                  <h4 class="text-white font-bold mb-2">📧 Communication</h4>
                  <ul class="space-y-1 text-sm ml-4">
                    <li>• Send account notifications and updates</li>
                    <li>• Respond to your inquiries and support requests</li>
                    <li>• Send promotional offers (with your consent)</li>
                    <li>• Provide customer service</li>
                  </ul>
                </div>

                <div class="card-glass p-4 bg-white/5">
                  <h4 class="text-white font-bold mb-2">📊 Analytics & Improvement</h4>
                  <ul class="space-y-1 text-sm ml-4">
                    <li>• Analyze usage patterns and preferences</li>
                    <li>• Improve our Services and user experience</li>
                    <li>• Develop new features and games</li>
                    <li>• Conduct market research</li>
                  </ul>
                </div>

                <div class="card-glass p-4 bg-white/5">
                  <h4 class="text-white font-bold mb-2">🛡️ Security & Protection</h4>
                  <ul class="space-y-1 text-sm ml-4">
                    <li>• Protect against fraud and abuse</li>
                    <li>• Ensure platform security and integrity</li>
                    <li>• Enforce our Terms and Conditions</li>
                    <li>• Resolve disputes and legal claims</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>

          <!-- Legal Basis -->
          <div id="legal" class="card-glass p-8 scroll-mt-24">
            <div class="flex items-center space-x-4 mb-6">
              <div class="w-14 h-14 bg-gradient-to-br from-accent-pink to-accent-red rounded-xl flex items-center justify-center text-2xl">
                ⚖️
              </div>
              <h2 class="text-3xl font-display font-black text-white">5. Legal Basis for Processing</h2>
            </div>
            
            <div class="space-y-4 text-gray-300 leading-relaxed">
              <p>Under GDPR, we process your personal data based on the following legal grounds:</p>
              
              <ul class="space-y-3">
                <li class="flex items-start space-x-3">
                  <span class="text-accent-green font-bold mt-1">✓</span>
                  <div>
                    <strong class="text-white">Contractual Necessity:</strong> Processing is necessary to perform our contract with you (providing gambling services).
                  </div>
                </li>
                <li class="flex items-start space-x-3">
                  <span class="text-accent-green font-bold mt-1">✓</span>
                  <div>
                    <strong class="text-white">Legal Obligation:</strong> Processing is required to comply with legal obligations (KYC, AML, tax reporting).
                  </div>
                </li>
                <li class="flex items-start space-x-3">
                  <span class="text-accent-green font-bold mt-1">✓</span>
                  <div>
                    <strong class="text-white">Legitimate Interests:</strong> Processing is necessary for our legitimate business interests (fraud prevention, service improvement).
                  </div>
                </li>
                <li class="flex items-start space-x-3">
                  <span class="text-accent-green font-bold mt-1">✓</span>
                  <div>
                    <strong class="text-white">Consent:</strong> You have given explicit consent for marketing communications and cookies.
                  </div>
                </li>
              </ul>
            </div>
          </div>

          <!-- Data Sharing -->
          <div id="sharing" class="card-glass p-8 scroll-mt-24">
            <div class="flex items-center space-x-4 mb-6">
              <div class="w-14 h-14 bg-gradient-to-br from-orange-500 to-red-600 rounded-xl flex items-center justify-center text-2xl">
                🤝
              </div>
              <h2 class="text-3xl font-display font-black text-white">6. Data Sharing & Disclosure</h2>
            </div>
            
            <div class="space-y-4 text-gray-300 leading-relaxed">
              <p>We may share your personal data with the following third parties:</p>
              
              <div class="space-y-3">
                <div class="card-glass p-4 bg-white/5">
                  <h4 class="text-white font-bold mb-2">🎮 Game Providers</h4>
                  <p class="text-sm">To provide access to games and track gameplay activity.</p>
                </div>

                <div class="card-glass p-4 bg-white/5">
                  <h4 class="text-white font-bold mb-2">💳 Payment Processors</h4>
                  <p class="text-sm">To process deposits, withdrawals, and verify payment methods.</p>
                </div>

                <div class="card-glass p-4 bg-white/5">
                  <h4 class="text-white font-bold mb-2">✅ Verification Services</h4>
                  <p class="text-sm">To verify your identity, age, and address (KYC compliance).</p>
                </div>

                <div class="card-glass p-4 bg-white/5">
                  <h4 class="text-white font-bold mb-2">📊 Analytics Providers</h4>
                  <p class="text-sm">To analyze website usage and improve our Services.</p>
                </div>

                <div class="card-glass p-4 bg-white/5">
                  <h4 class="text-white font-bold mb-2">🏛️ Regulatory Authorities</h4>
                  <p class="text-sm">To comply with legal obligations and licensing requirements.</p>
                </div>

                <div class="card-glass p-4 bg-white/5">
                  <h4 class="text-white font-bold mb-2">⚖️ Legal & Professional Advisors</h4>
                  <p class="text-sm">For legal advice, dispute resolution, and compliance purposes.</p>
                </div>
              </div>

              <div class="bg-primary-500/10 border-l-4 border-primary-500 p-4 rounded mt-4">
                <p class="text-primary-500 font-semibold">Important:</p>
                <p class="text-sm mt-2">We never sell your personal data to third parties. All third-party processors are bound by strict confidentiality agreements and data protection obligations.</p>
              </div>
            </div>
          </div>

          <!-- Data Security -->
          <div id="security" class="card-glass p-8 scroll-mt-24">
            <div class="flex items-center space-x-4 mb-6">
              <div class="w-14 h-14 bg-gradient-to-br from-primary-500 to-yellow-600 rounded-xl flex items-center justify-center text-2xl">
                🔒
              </div>
              <h2 class="text-3xl font-display font-black text-white">7. Data Security</h2>
            </div>
            
            <div class="space-y-6 text-gray-300 leading-relaxed">
              <p>
                We implement appropriate technical and organizational measures to protect your personal data against unauthorized access, loss, destruction, or alteration.
              </p>
              
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                {securityMeasures.map(measure => (
                  <div class="card-glass p-6 text-center space-y-3 hover:scale-105 transition-all duration-300 bg-white/5">
                    <div class="text-4xl">{measure.icon}</div>
                    <h4 class="text-white font-bold">{measure.measure}</h4>
                    <p class="text-sm text-gray-400">{measure.description}</p>
                  </div>
                ))}
              </div>

              <div class="bg-accent-red/10 border-l-4 border-accent-red p-4 rounded mt-4">
                <p class="text-accent-red font-semibold">Security Notice:</p>
                <p class="text-sm mt-2">While we implement robust security measures, no method of transmission over the internet is 100% secure. You are responsible for maintaining the confidentiality of your account credentials.</p>
              </div>
            </div>
          </div>

          <!-- Data Retention -->
          <div id="retention" class="card-glass p-8 scroll-mt-24">
            <div class="flex items-center space-x-4 mb-6">
              <div class="w-14 h-14 bg-gradient-to-br from-secondary-500 to-purple-600 rounded-xl flex items-center justify-center text-2xl">
                📅
              </div>
              <h2 class="text-3xl font-display font-black text-white">8. Data Retention</h2>
            </div>
            
            <div class="space-y-4 text-gray-300 leading-relaxed">
              <p>We retain your personal data for as long as necessary to fulfill the purposes outlined in this policy:</p>
              
              <ul class="space-y-3 ml-6">
                <li class="flex items-start space-x-3">
                  <span class="text-secondary-500 font-bold mt-1">•</span>
                  <div>
                    <strong class="text-white">Active Accounts:</strong> Data is retained while your account is active and for a reasonable period after closure.
                  </div>
                </li>
                <li class="flex items-start space-x-3">
                  <span class="text-secondary-500 font-bold mt-1">•</span>
                  <div>
                    <strong class="text-white">Legal Requirements:</strong> We retain data for at least 5 years after account closure to comply with AML and tax regulations.
                  </div>
                </li>
                <li class="flex items-start space-x-3">
                  <span class="text-secondary-500 font-bold mt-1">•</span>
                  <div>
                    <strong class="text-white">Dispute Resolution:</strong> Data may be retained longer if required for legal claims or disputes.
                  </div>
                </li>
                <li class="flex items-start space-x-3">
                  <span class="text-secondary-500 font-bold mt-1">•</span>
                  <div>
                    <strong class="text-white">Self-Exclusion:</strong> Data for self-excluded players is retained permanently to prevent re-registration.
                  </div>
                </li>
              </ul>

              <p class="mt-4">
                After the retention period expires, we securely delete or anonymize your personal data.
              </p>
            </div>
          </div>

          <!-- Your Rights -->
          <div id="rights" class="card-glass p-8 scroll-mt-24">
            <div class="flex items-center space-x-4 mb-6">
              <div class="w-14 h-14 bg-gradient-to-br from-accent-green to-emerald-600 rounded-xl flex items-center justify-center text-2xl">
                ✋
              </div>
              <h2 class="text-3xl font-display font-black text-white">9. Your Rights</h2>
            </div>
            
            <div class="space-y-6 text-gray-300 leading-relaxed">
              <p>Under GDPR and other data protection laws, you have the following rights:</p>
              
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {yourRights.map(right => (
                  <div class="card-glass p-6 hover:scale-105 transition-all duration-300 bg-white/5 flex flex-col">
                    <div class="flex items-start space-x-4 mb-4">
                      <div class="w-12 h-12 bg-gradient-to-br from-secondary-500 to-purple-600 rounded-xl flex items-center justify-center text-2xl flex-shrink-0">
                        {right.icon}
                      </div>
                      <div class="flex-1">
                        <h4 class="text-white font-bold mb-2">{right.right}</h4>
                        <p class="text-sm text-gray-400">{right.description}</p>
                      </div>
                    </div>
