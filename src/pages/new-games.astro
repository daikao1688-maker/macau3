---

<Layout title="New Games - CasinoPro | Latest Casino Releases">  
  <main class="min-h-screen pt-20">
    <!-- Hero Section -->
    <section class="relative py-20 overflow-hidden">
      <!-- Background -->
      <div class="absolute inset-0">
        <img 
          src="https://images.unsplash.com/photo-1522069169874-c58ec4b76be5?w=1920&h=600&fit=crop&q=80"
          alt="New Games Background"
          class="absolute inset-0 w-full h-full object-cover opacity-20"
        />
      </div>
      <div class="absolute inset-0 bg-gradient-to-br from-dark-950 via-dark-900 to-accent-green/20"></div>
      
      <!-- Animated circles -->
      <div class="absolute top-20 left-10 w-72 h-72 bg-accent-green/10 rounded-full blur-3xl animate-pulse-slow"></div>
      <div class="absolute bottom-20 right-10 w-96 h-96 bg-accent-blue/10 rounded-full blur-3xl animate-pulse-slow" style="animation-delay: 1s;"></div>
      
      <div class="container mx-auto px-4 relative z-10">
        <div class="max-w-4xl mx-auto text-center space-y-6">
          <span class="inline-block text-accent-green font-bold text-sm uppercase tracking-widest mb-4 px-6 py-2 bg-accent-green/10 rounded-full border border-accent-green/30 animate-pulse">
            🆕 Fresh Releases
          </span>
          
          <h1 class="text-5xl md:text-6xl lg:text-7xl font-display font-black leading-tight">
            <span class="text-gradient glow-text">New Games</span>
            <span class="block text-white mt-2">Latest Releases</span>
          </h1>
          
          <p class="text-xl md:text-2xl text-gray-300 max-w-3xl mx-auto leading-relaxed">
            Be the first to play the newest and most exciting casino games from top providers
          </p>
          
          <!-- Quick Stats -->
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4 pt-8">
            <div class="card-glass p-4">
              <div class="text-3xl font-display font-black text-accent-green">50+</div>
              <div class="text-sm text-gray-400">New Games</div>
            </div>
            <div class="card-glass p-4">
              <div class="text-3xl font-display font-black text-accent-green">12</div>
              <div class="text-sm text-gray-400">Exclusive</div>
            </div>
            <div class="card-glass p-4">
              <div class="text-3xl font-display font-black text-accent-green">Weekly</div>
              <div class="text-sm text-gray-400">Updates</div>
            </div>
            <div class="card-glass p-4">
              <div class="text-3xl font-display font-black text-accent-green">First</div>
              <div class="text-sm text-gray-400">To Play</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Categories Section -->
    <section class="section-padding bg-dark-900/50">
      <div class="container mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-display font-black text-white mb-4">
            Browse by <span class="text-gradient">Category</span>
          </h2>
          <p class="text-gray-400">Filter new releases by game type</p>
        </div>
        
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
          {categories.map(cat => (
            <button class="card-glass p-6 hover:scale-105 transition-all duration-300 group text-center">
              <div class="text-4xl mb-3">{cat.icon}</div>
              <h3 class="text-white font-bold text-sm mb-1 group-hover:text-accent-green transition-colors">{cat.name}</h3>
              <p class="text-gray-400 text-xs">{cat.count} games</p>
            </button>
          ))}
        </div>
      </div>
    </section>

    <!-- Filters & Search -->
    <section class="section-padding">
      <div class="container mx-auto">
        <div class="card-glass p-6 mb-8">
          <div class="flex flex-col md:flex-row gap-4">
            <!-- Search -->
            <div class="flex-1">
              <div class="relative">
                <input 
                  type="text" 
                  placeholder="Search new games..."
                  class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 pl-12 text-white placeholder-gray-500 focus:outline-none focus:border-accent-green transition-colors"
                />
                <svg class="w-5 h-5 text-gray-500 absolute left-4 top-1/2 transform -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
              </div>
            </div>
            
            <!-- Provider Filter -->
            <select class="bg-dark-800 border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-accent-green transition-colors cursor-pointer">
              <option value="" class="bg-dark-800 text-white">All Providers</option>
              <option value="netent" class="bg-dark-800 text-white">NetEnt</option>
              <option value="evolution" class="bg-dark-800 text-white">Evolution</option>
              <option value="pragmatic" class="bg-dark-800 text-white">Pragmatic Play</option>
              <option value="microgaming" class="bg-dark-800 text-white">Microgaming</option>
            </select>
            
            <!-- Sort -->
            <select class="bg-dark-800 border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-accent-green transition-colors cursor-pointer">
              <option value="newest" class="bg-dark-800 text-white">Newest First</option>
              <option value="popular" class="bg-dark-800 text-white">Most Popular</option>
              <option value="rating" class="bg-dark-800 text-white">Highest Rated</option>
              <option value="exclusive" class="bg-dark-800 text-white">Exclusive Only</option>
            </select>
          </div>
        </div>

        <!-- Games Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
          {newGames.map(game => (
            <div class="card-glass overflow-hidden hover:scale-105 transition-all duration-300 group relative grid grid-rows-[auto_1fr]">
              {game.isNew && (
                <div class="absolute top-0 right-0 bg-gradient-to-l from-accent-green to-transparent px-6 py-1 text-xs font-bold text-white z-30 animate-pulse">
                  🆕 NEW
                </div>
              )}
              
              {game.isExclusive && (
                <div class="absolute top-0 left-0 bg-gradient-to-r from-primary-500 to-transparent px-6 py-1 text-xs font-bold text-white z-30">
                  ⭐ EXCLUSIVE
                </div>
              )}
              
              <!-- Game Image -->
              <div class="relative h-48 overflow-hidden">
                <!-- Fallback gradient -->
                <div class="absolute inset-0 bg-gradient-to-br from-accent-green/30 to-accent-blue/30"></div>
                
                <img 
                  src={game.image}
                  alt={game.title}
                  class="absolute inset-0 w-full h-full object-cover z-10 group-hover:scale-110 transition-transform duration-500"
                  loading="lazy"
                />
                
                <!-- Gradient overlay -->
                <div class="absolute inset-0 bg-gradient-to-t from-dark-950 via-dark-950/50 to-transparent z-20"></div>
                
                <!-- Category Badge -->
                <div class="absolute bottom-3 left-3 z-30">
                  <span class="px-3 py-1 bg-accent-green/90 backdrop-blur-sm text-white text-xs font-bold rounded-full border border-white/20">
                    {game.category}
                  </span>
                </div>
              </div>

              <!-- Game Info -->
              <div class="p-4 flex flex-col">
                <div class="mb-3">
                  <h3 class="text-lg font-display font-bold text-white mb-1 group-hover:text-accent-green transition-colors">
                    {game.title}
                  </h3>
                  <div class="flex items-center justify-between text-xs">
                    <span class="text-gray-400">{game.provider}</span>
                    <span class="text-accent-green font-semibold">{game.releaseDate}</span>
                  </div>
                </div>

                <!-- Features -->
                <div class="flex flex-wrap gap-1 mb-3">
                  {game.features.slice(0, 3).map(feature => (
                    <span class="px-2 py-1 bg-white/5 text-gray-400 text-xs rounded-full border border-white/10">
                      {feature}
                    </span>
                  ))}
                </div>

                <!-- Stats -->
                <div class="flex items-center justify-between text-xs pt-2 mb-3 border-t border-white/10">
                  <div class="flex items-center space-x-1">
                    <svg class="w-4 h-4 text-primary-500" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                    <span class="text-white font-bold">{game.rating}</span>
                  </div>
                  <div class="flex items-center space-x-1 text-gray-400">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
                    </svg>
                    <span>{game.players}</span>
                  </div>
                  <div class="text-accent-green font-bold">
                    RTP {game.rtp}
                  </div>
                </div>

                <!-- Betting Range -->
                <div class="flex justify-between items-center pt-2 mb-3 border-t border-white/10 text-xs">
                  <div>
                    <span class="text-gray-400">Min:</span>
                    <span class="text-white font-bold ml-1">{game.minBet}</span>
                  </div>
                  <div>
                    <span class="text-gray-400">Max:</span>
                    <span class="text-accent-green font-bold ml-1">{game.maxBet}</span>
                  </div>
                </div>

                <!-- Play Button - pushed to bottom with mt-auto -->
                <button class="w-full bg-gradient-to-r from-accent-green to-accent-blue hover:from-accent-green/80 hover:to-accent-blue/80 text-white font-bold py-3 rounded-lg transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-accent-green/50 relative overflow-hidden group/btn mt-auto">
                  <span class="relative z-10">Play Now</span>
                  <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent transform -skew-x-12 -translate-x-full group-hover/btn:translate-x-full transition-transform duration-700"></div>
                </button>
              </div>
            </div>
          ))}
        </div>

        <!-- Load More -->
        <div class="text-center mt-12">
          <button class="btn-primary text-lg px-12 py-4">
            Load More Games
          </button>
          <p class="text-gray-400 text-sm mt-4">Showing 12 of 50+ new games</p>
        </div>
      </div>
    </section>

    <!-- Coming Soon Section -->
    <section class="section-padding bg-dark-900/50">
      <div class="container mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-display font-black text-white mb-4">
            <span class="text-gradient">Coming</span> Soon
          </h2>
          <p class="text-gray-400">Get ready for these upcoming releases</p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
          {upcomingGames.map(game => (
            <div class="card-glass p-6 hover:scale-105 transition-all duration-300 relative overflow-hidden flex flex-col">
              <!-- Coming Soon Badge -->
              <div class="absolute top-0 right-0 bg-gradient-to-l from-accent-blue to-transparent px-6 py-1 text-xs font-bold text-white">
                🔜 SOON
              </div>
              
              <div class="pt-4 flex flex-col flex-grow">
                <div class="mb-3">
                  <h3 class="text-xl font-display font-bold text-white mb-2">{game.title}</h3>
                  <div class="flex items-center justify-between text-sm mb-3">
                    <span class="text-gray-400">{game.provider}</span>
                    <span class="px-2 py-1 bg-accent-blue/20 text-accent-blue text-xs font-bold rounded-full border border-accent-blue/30">
                      {game.category}
                    </span>
                  </div>
                </div>
                
                <p class="text-gray-400 text-sm mb-4">{game.teaser}</p>
                
                <div class="flex items-center justify-between pt-4 border-t border-white/10 mt-auto">
                  <div>
                    <div class="text-xs text-gray-400">Release Date</div>
                    <div class="text-white font-bold">{game.releaseDate}</div>
                  </div>
                  <button class="px-4 py-2 bg-white/10 hover:bg-white/20 text-white text-sm font-semibold rounded-lg transition-colors border border-white/20">
                    Notify Me
                  </button>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Why Play New Games -->
    <section class="section-padding">
      <div class="container mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-display font-black text-white mb-4">
            Why Play <span class="text-gradient">New Games</span>?
          </h2>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="card-glass p-6 text-center space-y-4 hover:scale-105 transition-all duration-300">
            <div class="w-16 h-16 bg-gradient-to-br from-accent-green to-emerald-600 rounded-2xl flex items-center justify-center mx-auto">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
            </div>
            <h3 class="text-xl font-display font-bold text-white">Latest Features</h3>
            <p class="text-gray-400 text-sm">Experience cutting-edge game mechanics and innovative bonus features</p>
          </div>

          <div class="card-glass p-6 text-center space-y-4 hover:scale-105 transition-all duration-300">
            <div class="w-16 h-16 bg-gradient-to-br from-accent-blue to-blue-600 rounded-2xl flex items-center justify-center mx-auto">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
              </svg>
            </div>
            <h3 class="text-xl font-display font-bold text-white">Better Graphics</h3>
            <p class="text-gray-400 text-sm">Stunning HD graphics and immersive sound effects for premium experience</p>
          </div>

          <div class="card-glass p-6 text-center space-y-4 hover:scale-105 transition-all duration-300">
            <div class="w-16 h-16 bg-gradient-to-br from-primary-500 to-yellow-600 rounded-2xl flex items-center justify-center mx-auto">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
