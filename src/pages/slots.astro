    <!-- Top Providers -->
    <section class="section-padding">
      <div class="container mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-display font-black text-white mb-4">
            <span class="text-gradient">Top</span> Slot Providers
          </h2>
          <p class="text-gray-400">Games from the world's leading developers</p>
        </div>
        
        <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-8 gap-4">
          {providers.map(provider => (
            <div class="card-glass p-4 hover:scale-105 transition-all duration-300 text-center">
              <div class="text-white font-bold text-sm">{provider}</div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main></Layout>

<script>
  // Initialize slots page functionality
  document.addEventListener('DOMContentLoaded', async () => {
    // Dynamically import React components
    const { default: GameFilters } = await import('../components/GameFilters');
    const { createElement } = await import('react');
    const { createRoot } = await import('react-dom/client');
    const { games } = await import('../data/games');

    let filtersRoot;

    // Filter slots games
    const slotGames = games.filter(game => game.category === 'slots');

    // Initialize React components
    const initializeComponents = () => {
      // Initialize Game Filters
      const filtersContainer = document.getElementById('game-filters-container');
      if (filtersContainer && !filtersRoot) {
        filtersRoot = createRoot(filtersContainer);
        filtersRoot.render(
          createElement(GameFilters, {
            games: slotGames,
            onFilterChange: (filteredGames) => {
              renderGames(filteredGames);
            }
          })
        );
      }
    };

    // Render games grid
    const renderGames = (gamesToShow) => {
      const gamesContainer = document.getElementById('games-grid-container');
      if (!gamesContainer) return;

      const gamesHtml = `
        <div class="text-center mb-8">
          <h2 class="text-3xl md:text-4xl font-display font-black text-white mb-4">
            Featured <span class="text-gradient">Slot Games</span>
          </h2>
          <p class="text-gray-400">Discover our most popular and exciting slot games</p>
        </div>
        
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-6">
          ${gamesToShow.slice(0, 20).map(game => `
            <div class="game-card card-glass group hover:scale-105 transition-all duration-300 overflow-hidden cursor-pointer">
              <div class="relative">
                <img 
                  src="${game.image}" 
                  alt="${game.name}"
                  class="w-full h-48 object-cover group-hover:scale-110 transition-transform duration-500"
                  loading="lazy"
                />
                
                <!-- Overlay -->
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                
                <!-- Play Button -->
                <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                  <button class="btn-primary">
                    <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd"/>
                    </svg>
                    Play Now
                  </button>
                </div>

                <!-- Jackpot Badge -->
                ${game.hasJackpot ? `
                  <div class="absolute top-2 right-2 bg-gradient-to-r from-yellow-500 to-yellow-600 text-white text-xs font-bold px-2 py-1 rounded-full">
                    💰 JACKPOT
                  </div>
                ` : ''}

                <!-- New Badge -->
                ${game.isNew ? `
                  <div class="absolute top-2 left-2 bg-gradient-to-r from-accent-green to-green-600 text-white text-xs font-bold px-2 py-1 rounded-full">
                    🆕 NEW
                  </div>
                ` : ''}
              </div>

              <div class="p-4">
                <h3 class="text-white font-bold text-sm mb-1 group-hover:text-primary-500 transition-colors">
                  ${game.name}
                </h3>
                <p class="text-gray-400 text-xs mb-2">${game.provider}</p>
                
                <div class="flex items-center justify-between text-xs">
                  <div class="flex items-center space-x-1">
                    <span class="text-yellow-400">⭐</span>
                    <span class="text-gray-400">${game.rating}</span>
                  </div>
                  <div class="text-gray-400">RTP: ${game.rtp}%</div>
                </div>

                ${game.hasJackpot ? `
                  <div class="mt-2 text-center">
                    <div class="text-yellow-400 font-bold text-sm">
                      $${(Math.random() * 1000000 + 100000).toLocaleString('en-US', { maximumFractionDigits: 0 })}
                    </div>
                    <div class="text-gray-500 text-xs">Current Jackpot</div>
                  </div>
                ` : ''}
              </div>
            </div>
          `).join('')}
        </div>

        ${gamesToShow.length > 20 ? `
          <div class="text-center mt-12">
            <button class="btn-outline" onclick="loadMoreGames()">
              Load More Games
            </button>
            <p class="text-gray-400 text-sm mt-4">Showing 20 of ${gamesToShow.length} games</p>
          </div>
        ` : ''}
      `;

      gamesContainer.innerHTML = gamesHtml;
    };

    // Load more games functionality
    window.loadMoreGames = () => {
      console.log('Loading more games...');
    };

    // Initialize components and render initial games
    initializeComponents();
    renderGames(slotGames);
  });
</script>
