---
import { withBase } from '../utils/paths';
import Layout from '../layouts/Layout.astro';

const sections = [
  { id: 'introduction', title: 'Introduction', icon: '🍪' },
  { id: 'what-are', title: 'What Are Cookies', icon: '❓' },
  { id: 'types', title: 'Types of Cookies', icon: '📋' },
  { id: 'our-cookies', title: 'Cookies We Use', icon: '🔍' },
  { id: 'third-party', title: 'Third-Party Cookies', icon: '🤝' },
  { id: 'management', title: 'Cookie Management', icon: '⚙️' },
  { id: 'consent', title: 'Your Consent', icon: '✅' },
  { id: 'contact', title: 'Contact Us', icon: '📧' }
];

const cookieTypes = [
  {
    type: 'Strictly Necessary Cookies',
    icon: '🔧',
    color: 'from-accent-red to-red-600',
    required: true,
    description: 'Essential for the website to function properly. Cannot be disabled.',
    examples: [
      'Session management',
      'Security and authentication',
      'Load balancing',
      'Cookie consent preferences'
    ]
  },
  {
    type: 'Performance Cookies',
    icon: '📊',
    color: 'from-primary-500 to-yellow-600',
    required: false,
    description: 'Collect information about how visitors use our website to improve performance.',
    examples: [
      'Page visit statistics',
      'Error tracking',
      'Loading time analysis',
      'User journey mapping'
    ]
  },
  {
    type: 'Functional Cookies',
    icon: '⚙️',
    color: 'from-secondary-500 to-purple-600',
    required: false,
    description: 'Remember your preferences and settings for a personalized experience.',
    examples: [
      'Language preferences',
      'Currency selection',
      'Game favorites',
      'Display settings'
    ]
  },
  {
    type: 'Targeting/Advertising Cookies',
    icon: '🎯',
    color: 'from-accent-green to-emerald-600',
    required: false,
    description: 'Track your browsing to deliver relevant advertisements.',
    examples: [
      'Ad personalization',
      'Campaign tracking',
      'Retargeting',
      'Conversion tracking'
    ]
  }
];

const lastUpdated = 'January 1, 2026';
---

<Layout title="Cookie Policy - CasinoPro">  
  <main class="min-h-screen pt-20">
    <!-- Hero Section -->
    <section class="relative py-20 overflow-hidden">
      <div class="absolute inset-0">
        <img 
          src="https://images.unsplash.com/photo-1499951360447-b19be8fe80f5?w=1920&h=600&fit=crop&q=80"
          alt="Cookie Policy Background"
          class="absolute inset-0 w-full h-full object-cover opacity-10"
          loading="lazy"
        />
      </div>
      <div class="absolute inset-0 bg-gradient-to-br from-dark-950 via-dark-900 to-secondary-900/20"></div>
      
      <div class="absolute top-20 left-10 w-72 h-72 bg-secondary-500/10 rounded-full blur-3xl animate-pulse-slow"></div>
      <div class="absolute bottom-20 right-10 w-96 h-96 bg-primary-500/10 rounded-full blur-3xl animate-pulse-slow" style="animation-delay: 1s;"></div>
      
      <div class="container mx-auto px-4 relative z-10">
        <div class="max-w-4xl mx-auto text-center space-y-6">
          <span class="inline-block text-secondary-500 font-bold text-sm uppercase tracking-widest mb-4 px-6 py-2 bg-secondary-500/10 rounded-full border border-secondary-500/30">
            🍪 Cookie Information
          </span>
          
          <h1 class="text-5xl md:text-6xl lg:text-7xl font-display font-black leading-tight">
            <span class="text-gradient glow-text">Cookie Policy</span>
          </h1>
          
          <p class="text-xl md:text-2xl text-gray-300 max-w-3xl mx-auto leading-relaxed">
            Learn how we use cookies to enhance your experience
          </p>
          
          <div class="card-glass p-4 max-w-md mx-auto">
            <div class="text-sm text-gray-400">
              Last Updated: <span class="text-white font-semibold">{lastUpdated}</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Quick Navigation -->
    <section class="section-padding bg-dark-900/50">
      <div class="container mx-auto">
        <div class="text-center mb-8">
          <h2 class="text-2xl md:text-3xl font-display font-black text-white mb-4">
            Quick <span class="text-gradient">Navigation</span>
          </h2>
          <p class="text-gray-400">Jump to any section</p>
        </div>
        
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-5xl mx-auto">
          {sections.map(section => (
            <a 
              href={`#${section.id}`}
              class="card-glass p-4 hover:scale-105 transition-all duration-300 text-center space-y-2 group"
            >
              <div class="text-3xl">{section.icon}</div>
              <div class="text-sm font-bold text-white group-hover:text-secondary-500 transition-colors">
                {section.title}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Cookie Content -->
    <section class="section-padding">
      <div class="container mx-auto">
        <div class="max-w-4xl mx-auto space-y-12">
          
          <!-- Introduction -->
          <div id="introduction" class="card-glass p-8 scroll-mt-24">
            <div class="flex items-center space-x-4 mb-6">
              <div class="w-14 h-14 bg-gradient-to-br from-primary-500 to-yellow-600 rounded-xl flex items-center justify-center text-2xl">
                🍪
              </div>
              <h2 class="text-3xl font-display font-black text-white">1. Introduction</h2>
            </div>
            
            <div class="space-y-4 text-gray-300 leading-relaxed">
              <p>
                This Cookie Policy explains how CasinoPro ("we", "us", "our") uses cookies and similar tracking technologies when you visit our website and use our services.
              </p>
              <p>
                By using our website, you consent to the use of cookies in accordance with this policy. If you do not agree to our use of cookies, you should change your browser settings or discontinue use of our website.
              </p>
              <p>
                This policy should be read in conjunction with our <a href={withBase('/privacy-policy')} class="text-secondary-500 hover:text-secondary-400 underline">Privacy Policy</a> and <a href={withBase('/terms-and-conditions')} class="text-secondary-500 hover:text-secondary-400 underline">Terms and Conditions</a>.
              </p>
            </div>
          </div>

          <!-- What Are Cookies -->
          <div id="what-are" class="card-glass p-8 scroll-mt-24">
            <div class="flex items-center space-x-4 mb-6">
              <div class="w-14 h-14 bg-gradient-to-br from-secondary-500 to-purple-600 rounded-xl flex items-center justify-center text-2xl">
                ❓
              </div>
              <h2 class="text-3xl font-display font-black text-white">2. What Are Cookies?</h2>
            </div>
            
            <div class="space-y-4 text-gray-300 leading-relaxed">
              <p>
                Cookies are small text files that are placed on your device (computer, smartphone, tablet) when you visit a website. They are widely used to make websites work more efficiently and provide information to website owners.
              </p>
              
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6">
                <div class="card-glass p-6 bg-white/5">
                  <h3 class="text-lg font-bold text-white mb-3 flex items-center space-x-2">
                    <span class="text-2xl">📝</span>
                    <span>First-Party Cookies</span>
                  </h3>
                  <p class="text-sm">Set by the website you're visiting. Only that website can read them.</p>
                </div>

                <div class="card-glass p-6 bg-white/5">
                  <h3 class="text-lg font-bold text-white mb-3 flex items-center space-x-2">
                    <span class="text-2xl">🔗</span>
                    <span>Third-Party Cookies</span>
                  </h3>
                  <p class="text-sm">Set by external services (analytics, advertising) used on the website.</p>
                </div>

                <div class="card-glass p-6 bg-white/5">
                  <h3 class="text-lg font-bold text-white mb-3 flex items-center space-x-2">
                    <span class="text-2xl">⏱️</span>
                    <span>Session Cookies</span>
                  </h3>
                  <p class="text-sm">Temporary cookies deleted when you close your browser.</p>
                </div>

                <div class="card-glass p-6 bg-white/5">
                  <h3 class="text-lg font-bold text-white mb-3 flex items-center space-x-2">
                    <span class="text-2xl">💾</span>
                    <span>Persistent Cookies</span>
                  </h3>
                  <p class="text-sm">Remain on your device until they expire or you delete them.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Types of Cookies -->
          <div id="types" class="card-glass p-8 scroll-mt-24">
            <div class="flex items-center space-x-4 mb-6">
              <div class="w-14 h-14 bg-gradient-to-br from-accent-green to-emerald-600 rounded-xl flex items-center justify-center text-2xl">
                📋
              </div>
              <h2 class="text-3xl font-display font-black text-white">3. Types of Cookies We Use</h2>
            </div>
            
            <div class="space-y-6 text-gray-300 leading-relaxed">
              {cookieTypes.map(cookie => (
                <div class="card-glass p-6 bg-white/5">
                  <div class="flex items-start justify-between mb-4">
                    <div class="flex items-center space-x-4">
                      <div class={`w-14 h-14 bg-gradient-to-br ${cookie.color} rounded-xl flex items-center justify-center text-2xl flex-shrink-0`}>
                        {cookie.icon}
                      </div>
                      <div>
                        <h3 class="text-xl font-bold text-white">{cookie.type}</h3>
                        {cookie.required ? (
                          <span class="inline-block px-3 py-1 bg-accent-red/20 text-accent-red text-xs font-bold rounded-full mt-1">
                            REQUIRED
                          </span>
                        ) : (
                          <span class="inline-block px-3 py-1 bg-accent-green/20 text-accent-green text-xs font-bold rounded-full mt-1">
                            OPTIONAL
                          </span>
                        )}
                      </div>
                    </div>
                  </div>
                  
                  <p class="text-sm mb-4">{cookie.description}</p>
                  
                  <div class="border-t border-white/10 pt-4">
                    <h4 class="text-white font-semibold text-sm mb-2">Examples:</h4>
                    <ul class="space-y-1">
                      {cookie.examples.map(example => (
                        <li class="flex items-start space-x-2 text-sm">
                          <span class="text-secondary-500 mt-1">•</span>
                          <span>{example}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- Cookies We Use -->
          <div id="our-cookies" class="card-glass p-8 scroll-mt-24">
            <div class="flex items-center space-x-4 mb-6">
              <div class="w-14 h-14 bg-gradient-to-br from-accent-blue to-blue-600 rounded-xl flex items-center justify-center text-2xl">
                🔍
              </div>
              <h2 class="text-3xl font-display font-black text-white">4. Specific Cookies We Use</h2>
            </div>
            
            <div class="space-y-4 text-gray-300 leading-relaxed">
              <p>Below is a detailed list of cookies we use on our website:</p>
              
              <div class="overflow-x-auto">
                <table class="w-full text-sm">
                  <thead>
                    <tr class="border-b border-white/20">
                      <th class="text-left py-3 px-4 text-white font-bold">Cookie Name</th>
                      <th class="text-left py-3 px-4 text-white font-bold">Purpose</th>
                      <th class="text-left py-3 px-4 text-white font-bold">Type</th>
                      <th class="text-left py-3 px-4 text-white font-bold">Duration</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-white/10">
                    <tr class="hover:bg-white/5">
                      <td class="py-3 px-4 font-mono text-xs">session_id</td>
                      <td class="py-3 px-4">Maintains your login session</td>
                      <td class="py-3 px-4"><span class="px-2 py-1 bg-accent-red/20 text-accent-red text-xs rounded">Necessary</span></td>
                      <td class="py-3 px-4">Session</td>
                    </tr>
                    <tr class="hover:bg-white/5">
                      <td class="py-3 px-4 font-mono text-xs">csrf_token</td>
                      <td class="py-3 px-4">Security protection against attacks</td>
                      <td class="py-3 px-4"><span class="px-2 py-1 bg-accent-red/20 text-accent-red text-xs rounded">Necessary</span></td>
                      <td class="py-3 px-4">Session</td>
                    </tr>
                    <tr class="hover:bg-white/5">
                      <td class="py-3 px-4 font-mono text-xs">cookie_consent</td>
                      <td class="py-3 px-4">Stores your cookie preferences</td>
                      <td class="py-3 px-4"><span class="px-2 py-1 bg-accent-red/20 text-accent-red text-xs rounded">Necessary</span></td>
                      <td class="py-3 px-4">1 year</td>
                    </tr>
                    <tr class="hover:bg-white/5">
                      <td class="py-3 px-4 font-mono text-xs">language</td>
                      <td class="py-3 px-4">Remembers your language preference</td>
                      <td class="py-3 px-4"><span class="px-2 py-1 bg-secondary-500/20 text-secondary-500 text-xs rounded">Functional</span></td>
                      <td class="py-3 px-4">1 year</td>
                    </tr>
                    <tr class="hover:bg-white/5">
                      <td class="py-3 px-4 font-mono text-xs">currency</td>
                      <td class="py-3 px-4">Remembers your currency selection</td>
                      <td class="py-3 px-4"><span class="px-2 py-1 bg-secondary-500/20 text-secondary-500 text-xs rounded">Functional</span></td>
                      <td class="py-3 px-4">1 year</td>
                    </tr>
                    <tr class="hover:bg-white/5">
                      <td class="py-3 px-4 font-mono text-xs">_ga</td>
                      <td class="py-3 px-4">Google Analytics - tracks visitors</td>
                      <td class="py-3 px-4"><span class="px-2 py-1 bg-primary-500/20 text-primary-500 text-xs rounded">Performance</span></td>
                      <td class="py-3 px-4">2 years</td>
                    </tr>
                    <tr class="hover:bg-white/5">
                      <td class="py-3 px-4 font-mono text-xs">_gid</td>
                      <td class="py-3 px-4">Google Analytics - distinguishes users</td>
                      <td class="py-3 px-4"><span class="px-2 py-1 bg-primary-500/20 text-primary-500 text-xs rounded">Performance</span></td>
                      <td class="py-3 px-4">24 hours</td>
                    </tr>
                    <tr class="hover:bg-white/5">
                      <td class="py-3 px-4 font-mono text-xs">_fbp</td>
                      <td class="py-3 px-4">Facebook Pixel - ad tracking</td>
                      <td class="py-3 px-4"><span class="px-2 py-1 bg-accent-green/20 text-accent-green text-xs rounded">Advertising</span></td>
                      <td class="py-3 px-4">3 months</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <!-- Third-Party Cookies -->
          <div id="third-party" class="card-glass p-8 scroll-mt-24">
            <div class="flex items-center space-x-4 mb-6">
              <div class="w-14 h-14 bg-gradient-to-br from-accent-pink to-accent-red rounded-xl flex items-center justify-center text-2xl">
                🤝
              </div>
              <h2 class="text-3xl font-display font-black text-white">5. Third-Party Cookies</h2>
            </div>
            
            <div class="space-y-4 text-gray-300 leading-relaxed">
              <p>
                We use services from third-party companies that may set their own cookies. We do not control these cookies and recommend reviewing their privacy policies:
              </p>
              
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6">
                <div class="card-glass p-6 bg-white/5">
                  <h3 class="text-lg font-bold text-white mb-3">📊 Google Analytics</h3>
                  <p class="text-sm mb-3">Analyzes website traffic and user behavior</p>
                  <a href="https://policies.google.com/privacy" target="_blank" class="text-secondary-500 hover:text-secondary-400 text-sm underline">
                    Privacy Policy →
                  </a>
                </div>

                <div class="card-glass p-6 bg-white/5">
                  <h3 class="text-lg font-bold text-white mb-3">📘 Facebook Pixel</h3>
                  <p class="text-sm mb-3">Tracks conversions and delivers targeted ads</p>
                  <a href="https://www.facebook.com/privacy" target="_blank" class="text-secondary-500 hover:text-secondary-400 text-sm underline">
                    Privacy Policy →
                  </a>
                </div>

                <div class="card-glass p-6 bg-white/5">
                  <h3 class="text-lg font-bold text-white mb-3">🎯 Google Ads</h3>
                  <p class="text-sm mb-3">Delivers personalized advertisements</p>
                  <a href="https://policies.google.com/technologies/ads" target="_blank" class="text-secondary-500 hover:text-secondary-400 text-sm underline">
                    Privacy Policy →
                  </a>
                </div>

                <div class="card-glass p-6 bg-white/5">
                  <h3 class="text-lg font-bold text-white mb-3">💬 Intercom</h3>
                  <p class="text-sm mb-3">Powers our live chat support system</p>
                  <a href="https://www.intercom.com/legal/privacy" target="_blank" class="text-secondary-500 hover:text-secondary-400 text-sm underline">
                    Privacy Policy →
                  </a>
                </div>

                <div class="card-glass p-6 bg-white/5">
                  <h3 class="text-lg font-bold text-white mb-3">🎮 Game Providers</h3>
                  <p class="text-sm mb-3">Cookies from game providers (NetEnt, Microgaming, etc.)</p>
                  <span class="text-secondary-500 text-sm">Various policies apply</span>
                </div>

                <div class="card-glass p-6 bg-white/5">
                  <h3 class="text-lg font-bold text-white mb-3">💳 Payment Processors</h3>
                  <p class="text-sm mb-3">Secure payment processing cookies</p>
                  <span class="text-secondary-500 text-sm">Various policies apply</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Cookie Management -->
          <div id="management" class="card-glass p-8 scroll-mt-24">
            <div class="flex items-center space-x-4 mb-6">
              <div class="w-14 h-14 bg-gradient-to-br from-orange-500 to-red-600 rounded-xl flex items-center justify-center text-2xl">
                ⚙️
              </div>
              <h2 class="text-3xl font-display font-black text-white">6. Managing Cookies</h2>
            </div>
            
            <div class="space-y-6 text-gray-300 leading-relaxed">
              <p>
                You have the right to accept or reject cookies. You can manage your cookie preferences through:
              </p>

              <div class="card-glass p-6 bg-white/5">
                <h3 class="text-lg font-bold text-white mb-4">🍪 Cookie Consent Banner</h3>
                <p class="text-sm mb-4">When you first visit our website, you'll see a cookie banner where you can:</p>
                <ul class="space-y-2 text-sm ml-6">
                  <li>• Accept all cookies</li>
                  <li>• Reject optional cookies</li>
                  <li>• Customize your preferences by cookie type</li>
                </ul>
                <button class="mt-4 bg-gradient-to-r from-primary-500 to-secondary-500 hover:from-primary-600 hover:to-secondary-600 text-white font-bold py-2 px-6 rounded-lg transition-all duration-300">
                  Manage Cookie Preferences
                </button>
              </div>

              <div class="card-glass p-6 bg-white/5">
                <h3 class="text-lg font-bold text-white mb-4">🌐 Browser Settings</h3>
                <p class="text-sm mb-4">You can also control cookies through your browser settings:</p>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <div class="space-y-2">
                    <h4 class="text-white font-semibold text-sm">Chrome</h4>
                    <p class="text-xs">Settings → Privacy and security → Cookies</p>
                  </div>
                  <div class="space-y-2">
                    <h4 class="text-white font-semibold text-sm">Firefox</h4>
                    <p class="text-xs">Options → Privacy & Security → Cookies</p>
                  </div>
                  <div class="space-y-2">
                    <h4 class="text-white font-semibold text-sm">Safari</h4>
                    <p class="text-xs">Preferences → Privacy → Cookies</p>
                  </div>
                  <div class="space-y-2">
                    <h4 class="text-white font-semibold text-sm">Edge</h4>
                    <p class="text-xs">Settings → Privacy → Cookies</p>
                  </div>
                </div>
              </div>

              <div class="bg-primary-500/10 border-l-4 border-primary-500 p-4 rounded">
                <p class="text-primary-500 font-semibold">Important Notice:</p>
                <p class="text-sm mt-2">Blocking or deleting cookies may affect your ability to use certain features of our website. Strictly necessary cookies cannot be disabled as they are essential for the website to function.</p>
              </div>
            </div>
          </div>

          <!-- Your Consent -->
          <div id="consent" class="card-glass p-8 scroll-mt-24">
            <div class="flex items-center space-x-4 mb-6">
              <div class="w-14 h-14 bg-gradient-to-br from-primary-500 to-yellow-600 rounded-xl flex items-center justify-center text-2xl">
                ✅
              </div>
              <h2 class="text-3xl font-display font-black text-white">7. Your Consent</h2>
            </div>
            
            <div class="space-y-4 text-gray-300 leading-relaxed">
              <p>
                By using our website, you consent to the use of strictly necessary cookies. For optional cookies (performance, functional, advertising), we will ask for your explicit consent through our cookie banner.
              </p>

              <h3 class="text-xl font-bold text-white mt-6">Withdrawing Consent</h3>
              <p>
                You can withdraw your consent at any time by:
              </p>
              <ul class="space-y-2 ml-6">
                <li>• Changing your cookie preferences through our cookie settings</li>
                <li>• Deleting cookies through your browser settings</li>
                <li>• Contacting us at <a href="mailto:privacy@casinopro.com" class="text-secondary-500 hover:text-secondary-400 underline">privacy@casinopro.com</a></li>
              </ul>

              <h3 class="text-xl font-bold text-white mt-6">Do Not Track (DNT)</h3>
              <p>
                Some browsers have a "Do Not Track" feature that signals to websites that you don't want your online activities tracked. We currently do not respond to DNT signals, but you can manage cookies through your browser settings or our cookie preferences.
              </p>
            </div>
          </div>

          <!-- Contact Us -->
          <div id="contact" class="card-glass p-8 scroll-mt-24">
            <div class="flex items-center space-x-4 mb-6">
              <div class="w-14 h-14 bg-gradient-to-br from-secondary-500 to-purple-600 rounded-xl flex items-center justify-center text-2xl">
                📧
              </div>
              <h2 class="text-3xl font-display font-black text-white">8. Contact Us</h2>
            </div>
            
            <div class="space-y-4 text-gray-300 leading-relaxed">
              <p>
                If you have any questions about our use of cookies, please contact us:
              </p>
              
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6">
                <div class="card-glass p-6 bg-white/5">
                  <h4 class="text-white font-bold mb-4">📧 Email</h4>
                  <p class="text-sm mb-2">Cookie & Privacy Inquiries:</p>
                  <a href="mailto:privacy@casinopro.com" class="text-secondary-500 hover:text-secondary-400">privacy@casinopro.com</a>
                </div>

                <div class="card-glass p-6 bg-white/5">
                  <h4 class="text-white font-bold mb-4">💬 Live Chat</h4>
                  <p class="text-sm mb-4">Available 24/7 for immediate assistance</p>
                  <button class="w-full bg-gradient-to-r from-primary-500 to-secondary-500 hover:from-primary-600 hover:to-secondary-600 text-white font-bold py-2 rounded-lg transition-all duration-300">
                    Start Live Chat
                  </button>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="section-padding bg-dark-900/50">
      <div class="container mx-auto">
        <div class="card-glass p-12 text-center space-y-6 relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-br from-secondary-500/10 via-primary-500/10 to-transparent"></div>
          <div class="absolute top-0 right-0 w-64 h-64 bg-secondary-500/20 rounded-full blur-3xl"></div>
          <div class="absolute bottom-0 left-0 w-64 h-64 bg-primary-500/20 rounded-full blur-3xl"></div>
          
          <div class="relative z-10">
            <div class="text-6xl mb-4">🍪</div>
            <h2 class="text-4xl md:text-5xl font-display font-black text-white mb-4">
              Manage Your <span class="text-gradient">Cookie Preferences</span>
            </h2>
            <p class="text-xl text-gray-300 mb-8 max-w-2xl mx-auto">
              You're in control. Customize your cookie settings anytime
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <button class="btn-primary text-lg px-12 py-4">
                Cookie Settings
              </button>
              <a href={withBase('/privacy-policy')} class="border-2 border-white/20 text-white hover:bg-white/10 font-bold py-4 px-12 rounded-lg transition-all duration-300 text-lg">
                Privacy Policy
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main></Layout>

<script>
  // Smooth scroll for navigation links
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
      e.preventDefault();
      const target = document.querySelector(this.getAttribute('href') as string);
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  // Highlight current section in navigation
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.getAttribute('id');
        document.querySelectorAll('a[href^="#"]').forEach(link => {
          link.classList.remove('ring-2', 'ring-secondary-500');
          if (link.getAttribute('href') === `#${id}`) {
            link.classList.add('ring-2', 'ring-secondary-500');
          }
        });
      }
    });
  }, { threshold: 0.5 });

  document.querySelectorAll('[id]').forEach(section => {
    observer.observe(section);
  });
</script>
