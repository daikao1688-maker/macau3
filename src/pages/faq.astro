<script>
  // Search functionality
  const searchInput = document.getElementById('faq-search') as HTMLInputElement;
  const faqCategories = document.querySelectorAll('.faq-category');
  
  searchInput?.addEventListener('input', (e) => {
    const searchTerm = (e.target as HTMLInputElement).value.toLowerCase();
    
    faqCategories.forEach(category => {
      const questions = category.querySelectorAll('details');
      let hasVisibleQuestion = false;
      
      questions.forEach(question => {
        const questionText = question.querySelector('summary')?.textContent?.toLowerCase() || '';
        const answerText = question.querySelector('p')?.textContent?.toLowerCase() || '';
        
        if (questionText.includes(searchTerm) || answerText.includes(searchTerm)) {
          (question as HTMLElement).style.display = 'block';
          hasVisibleQuestion = true;
        } else {
          (question as HTMLElement).style.display = 'none';
        }
      });
      
      // Hide category if no questions match
      (category as HTMLElement).style.display = hasVisibleQuestion ? 'block' : 'none';
    });
  });
  
  // Category filter buttons
  const categoryButtons = document.querySelectorAll('.category-btn');
  
  categoryButtons.forEach(button => {
    button.addEventListener('click', () => {
      const categoryId = button.getAttribute('data-category');
      const targetCategory = document.querySelector(`.faq-category[data-category="${categoryId}"]`);
      
      if (targetCategory) {
        targetCategory.scrollIntoView({ behavior: 'smooth', block: 'start' });
        
        // Highlight the category briefly
        targetCategory.classList.add('ring-2', 'ring-secondary-500', 'rounded-lg');
        setTimeout(() => {
          targetCategory.classList.remove('ring-2', 'ring-secondary-500', 'rounded-lg');
        }, 2000);
      }
    });
  });
  
  // Track which FAQs are opened (analytics placeholder)
  const allDetails = document.querySelectorAll('details');
  allDetails.forEach(detail => {
    detail.addEventListener('toggle', () => {
      if (detail.open) {
        const question = detail.querySelector('summary')?.textContent;
        console.log('FAQ opened:', question);
        // In production, send to analytics
      }
    });
  });
</script>
