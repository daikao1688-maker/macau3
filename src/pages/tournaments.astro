const categories = [
  { name: 'All Tournaments', count: '25+', icon: '🏆' },
  { name: 'Slots', count: '12', icon: '🎰' },
  { name: 'Table Games', count: '6', icon: '🃏' },
  { name: 'Live Casino', count: '5', icon: '🎥' },
  { name: 'Poker', count: '4', icon: '♠️' },
  { name: 'Ending Soon', count: '3', icon: '⚡' }
];

const leaderboard = [
  { rank: 1, username: 'LuckyAce777', points: 125840, prize: '$100,000', avatar: 'https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?w=100&h=100&fit=crop&q=80' },
