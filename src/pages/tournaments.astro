---

<Layout title="Tournaments - CasinoPro | Compete for Massive Prize Pools">  
  <main class="min-h-screen pt-20">
    <!-- Hero Section -->
    <section class="relative py-20 overflow-hidden">
      <!-- Background -->
      <div class="absolute inset-0">
        <img 
          src="https://images.unsplash.com/photo-1522069169874-c58ec4b76be5?w=1920&h=600&fit=crop&q=80"
          alt="Tournaments Background"
          class="absolute inset-0 w-full h-full object-cover opacity-20"
        />
      </div>
      <div class="absolute inset-0 bg-gradient-to-br from-dark-950 via-dark-900 to-primary-900/20"></div>
      
      <!-- Animated circles -->
      <div class="absolute top-20 left-10 w-72 h-72 bg-primary-500/10 rounded-full blur-3xl animate-pulse-slow"></div>
      <div class="absolute bottom-20 right-10 w-96 h-96 bg-secondary-500/10 rounded-full blur-3xl animate-pulse-slow" style="animation-delay: 1s;"></div>
      
      <div class="container mx-auto px-4 relative z-10">
        <div class="max-w-4xl mx-auto text-center space-y-6">
          <span class="inline-block text-primary-500 font-bold text-sm uppercase tracking-widest mb-4 px-6 py-2 bg-primary-500/10 rounded-full border border-primary-500/30">
            🏆 Elite Competitions
          </span>
          
          <h1 class="text-5xl md:text-6xl lg:text-7xl font-display font-black leading-tight">
            <span class="text-gradient glow-text">Premium Tournaments</span>
            <span class="block text-white mt-2">Compete & Win Big</span>
          </h1>
          
          <p class="text-xl md:text-2xl text-gray-300 max-w-3xl mx-auto leading-relaxed">
            Join elite competitions with massive prize pools and compete against the best players worldwide
          </p>
          
          <!-- Quick Stats -->
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4 pt-8">
            <div class="card-glass p-4">
              <div class="text-3xl font-display font-black text-primary-500">$2.5M</div>
              <div class="text-sm text-gray-400">Total Prizes</div>
            </div>
            <div class="card-glass p-4">
              <div class="text-3xl font-display font-black text-primary-500">25+</div>
              <div class="text-sm text-gray-400">Active Now</div>
            </div>
            <div class="card-glass p-4">
              <div class="text-3xl font-display font-black text-primary-500">50K+</div>
              <div class="text-sm text-gray-400">Players</div>
            </div>
            <div class="card-glass p-4">
              <div class="text-3xl font-display font-black text-primary-500">Daily</div>
              <div class="text-sm text-gray-400">New Events</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Categories Section -->
    <section class="section-padding bg-dark-900/50">
      <div class="container mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-display font-black text-white mb-4">
            Browse by <span class="text-gradient">Category</span>
          </h2>
          <p class="text-gray-400">Find tournaments that match your gaming style</p>
        </div>
        
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
          {categories.map(cat => (
            <button class="card-glass p-6 hover:scale-105 transition-all duration-300 group text-center">
              <div class="text-4xl mb-3">{cat.icon}</div>
              <h3 class="text-white font-bold text-sm mb-1 group-hover:text-primary-500 transition-colors">{cat.name}</h3>
              <p class="text-gray-400 text-xs">{cat.count} events</p>
            </button>
          ))}
        </div>
      </div>
    </section>

    <!-- Filters & Search -->
    <section class="section-padding">
      <div class="container mx-auto">
        <div class="card-glass p-6 mb-8">
          <div class="flex flex-col md:flex-row gap-4">
            <!-- Search -->
            <div class="flex-1">
              <div class="relative">
                <input 
                  type="text" 
                  placeholder="Search tournaments..."
                  class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 pl-12 text-white placeholder-gray-500 focus:outline-none focus:border-primary-500 transition-colors"
                />
                <svg class="w-5 h-5 text-gray-500 absolute left-4 top-1/2 transform -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
              </div>
            </div>
            
            <!-- Entry Fee Filter -->
            <select class="bg-dark-800 border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-primary-500 transition-colors cursor-pointer">
              <option value="" class="bg-dark-800 text-white">All Entry Fees</option>
              <option value="free" class="bg-dark-800 text-white">Free Entry</option>
              <option value="low" class="bg-dark-800 text-white">$1 - $50</option>
              <option value="medium" class="bg-dark-800 text-white">$51 - $150</option>
              <option value="high" class="bg-dark-800 text-white">$151+</option>
            </select>
            
            <!-- Sort -->
            <select class="bg-dark-800 border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-primary-500 transition-colors cursor-pointer">
              <option value="prize" class="bg-dark-800 text-white">Highest Prize Pool</option>
              <option value="ending" class="bg-dark-800 text-white">Ending Soon</option>
              <option value="new" class="bg-dark-800 text-white">Newest</option>
              <option value="popular" class="bg-dark-800 text-white">Most Popular</option>
            </select>
          </div>
        </div>

        <!-- Tournaments List -->
        <div class="space-y-6 max-w-6xl mx-auto">
          {tournaments.map(tournament => (
            <div class={`card-glass p-6 md:p-8 hover:scale-[1.02] transition-all duration-300 relative overflow-hidden group ${tournament.featured ? 'ring-2 ring-primary-500/50' : ''}`}>
              {tournament.featured && (
                <div class="absolute top-0 left-0 bg-gradient-to-r from-primary-500 to-transparent px-8 py-2 text-sm font-bold text-white z-10">
                  ⭐ FEATURED
                </div>
              )}
              
              <!-- Background decoration -->
              <div class="absolute top-0 right-0 w-64 h-64 bg-gradient-to-br from-primary-500/10 to-secondary-500/10 rounded-full blur-3xl"></div>
              
              {tournament.status === 'ending-soon' && (
                <div class="absolute top-0 right-0 bg-gradient-to-l from-accent-red via-accent-red to-transparent px-8 py-2 text-sm font-bold text-white animate-pulse z-10">
                  ⚡ ENDING SOON
                </div>
              )}
              
              <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6 relative z-10">
                <!-- Tournament Icon & Info -->
                <div class="flex-1 space-y-4">
                  <div class="flex items-start gap-4">
                    <!-- Large Icon with Real Image -->
                    <div class="flex-shrink-0 w-24 h-24 rounded-2xl overflow-hidden shadow-lg group-hover:scale-110 transition-transform relative">
                      <!-- Fallback gradient -->
                      <div class="absolute inset-0 bg-gradient-to-br from-primary-500 to-secondary-500"></div>
                      
                      <img 
                        src={tournament.image}
                        alt={tournament.type}
                        class="absolute inset-0 w-full h-full object-cover z-10"
                        loading="lazy"
                      />
                      <div class="absolute inset-0 bg-gradient-to-br from-primary-500/60 to-secondary-500/60 z-20"></div>
                      <div class="absolute inset-0 flex items-center justify-center text-4xl z-30">
                        {tournament.type === 'Slots' ? '🎰' : tournament.type === 'Table Games' ? '🃏' : tournament.type === 'Live Casino' ? '🎥' : '♠️'}
                      </div>
                    </div>
                    
                    <div class="flex-1">
                      <div class="flex items-center space-x-3 mb-2">
                        <h3 class="text-2xl md:text-3xl font-display font-black text-white group-hover:text-primary-500 transition-colors">
                          {tournament.name}
                        </h3>
                      </div>
                      <div class="flex flex-wrap items-center gap-3 mb-3">
                        <span class="px-4 py-1.5 bg-gradient-to-r from-primary-500/20 to-primary-600/20 rounded-full text-primary-400 text-xs font-bold border border-primary-500/30 shadow-lg">
                          {tournament.type}
                        </span>
                        <span class="px-4 py-1.5 bg-gradient-to-r from-white/5 to-white/10 rounded-full text-gray-300 text-xs font-semibold border border-white/10">
                          Entry: {tournament.entryFee}
                        </span>
                        <span class="px-4 py-1.5 bg-gradient-to-r from-accent-green/20 to-emerald-600/20 rounded-full text-accent-green text-xs font-bold border border-accent-green/30 shadow-lg">
                          🏆 1st Prize: {tournament.topPrize}
                        </span>
                      </div>
                      <div class="text-sm text-gray-400">
                        <span>{tournament.startDate}</span> - <span>{tournament.endDate}</span>
                        <span class="mx-2">•</span>
                        <span>Min Bet: {tournament.minBet}</span>
                      </div>
                    </div>
                  </div>

                  <!-- Stats Grid -->
                  <div class="grid grid-cols-3 gap-6 pt-4">
                    <div class="space-y-1 text-center lg:text-left">
                      <p class="text-gray-400 text-xs uppercase tracking-wider font-semibold">Total Prize Pool</p>
                      <p class="text-primary-500 font-display font-black text-2xl md:text-3xl">{tournament.prizePool}</p>
                    </div>
                    <div class="space-y-1 text-center lg:text-left">
                      <p class="text-gray-400 text-xs uppercase tracking-wider font-semibold">Participants</p>
                      <p class="text-white font-display font-black text-2xl md:text-3xl">{tournament.participants.toLocaleString()}</p>
                    </div>
                    <div class="space-y-1 text-center lg:text-left">
                      <p class="text-gray-400 text-xs uppercase tracking-wider font-semibold">Time Remaining</p>
                      <p class="text-white font-display font-black text-2xl md:text-3xl">{tournament.endsIn}</p>
                    </div>
                  </div>

                  <!-- Progress Bar -->
                  <div class="space-y-2 pt-2">
                    <div class="flex justify-between text-sm">
                      <span class="text-gray-400 font-semibold">Tournament Progress</span>
                      <span class="text-white font-bold">{tournament.progress}% Complete</span>
                    </div>
                    <div class="w-full bg-white/10 rounded-full h-3 overflow-hidden border border-white/20 shadow-inner">
                      <div 
                        class="bg-gradient-to-r from-primary-500 via-secondary-500 to-primary-500 h-full rounded-full transition-all duration-500 relative overflow-hidden shadow-lg"
                        style={`width: ${tournament.progress}%`}
                      >
                        <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/30 to-transparent animate-shimmer"></div>
                      </div>
                    </div>
                  </div>

                  <!-- Prize Breakdown -->
                  <div class="pt-4 border-t border-white/10">
                    <p class="text-gray-400 text-xs font-semibold mb-2">Top 5 Prizes:</p>
                    <div class="flex flex-wrap gap-2">
                      {tournament.prizes.map((prize, index) => (
                        <span class="px-3 py-1 bg-white/5 rounded-full text-xs font-bold border border-white/10">
                          <span class="text-primary-500">#{index + 1}</span> <span class="text-white">{prize}</span>
                        </span>
                      ))}
                    </div>
                  </div>
                </div>

                <!-- Join Button -->
                <div class="lg:w-56 space-y-3">
                  <button class="w-full btn-primary py-4 text-lg whitespace-nowrap relative overflow-hidden group/btn shadow-xl">
                    <span class="relative z-10 flex items-center justify-center">
                      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                      </svg>
                      Join Tournament
                    </span>
                    <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent transform -skew-x-12 -translate-x-full group-hover/btn:translate-x-full transition-transform duration-700"></div>
                  </button>
                  <button class="w-full text-gray-400 hover:text-white transition-colors text-sm font-semibold flex items-center justify-center space-x-2 group/link py-2 hover:bg-white/5 rounded-lg">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                    </svg>
                    <span>View Leaderboard</span>
                    <svg class="w-4 h-4 group-hover/link:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                  </button>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Leaderboard Section -->
    <section class="section-padding bg-dark-900/50">
      <div class="container mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-display font-black text-white mb-4">
            <span class="text-gradient">Current</span> Leaderboard
          </h2>
          <p class="text-gray-400">Top players in Grand Slots Championship</p>
        </div>
        
        <div class="max-w-4xl mx-auto">
          <div class="card-glass overflow-hidden">
            <!-- Leaderboard Header -->
            <div class="bg-gradient-to-r from-primary-500/20 to-secondary-500/20 p-6 border-b border-white/10">
              <div class="grid grid-cols-12 gap-4 text-sm font-bold text-gray-400 uppercase tracking-wider">
                <div class="col-span-1">Rank</div>
                <div class="col-span-5">Player</div>
                <div class="col-span-3 text-right">Points</div>
                <div class="col-span-3 text-right">Prize</div>
              </div>
            </div>
            
            <!-- Leaderboard Entries -->
            <div class="divide-y divide-white/10">
              {leaderboard.map((player, index) => (
                <div class={`p-6 hover:bg-white/5 transition-colors ${index < 3 ? 'bg-gradient-to-r from-primary-500/5 to-transparent' : ''}`}>
                  <div class="grid grid-cols-12 gap-4 items-center">
                    <!-- Rank -->
                    <div class="col-span-1">
                      {player.rank <= 3 ? (
                        <div class={`w-10 h-10 rounded-full flex items-center justify-center font-display font-black text-lg ${
                          player.rank === 1 ? 'bg-gradient-to-br from-yellow-400 to-yellow-600 text-white' :
                          player.rank === 2 ? 'bg-gradient-to-br from-gray-300 to-gray-500 text-white' :
                          'bg-gradient-to-br from-orange-400 to-orange-600 text-white'
                        }`}>
                          {player.rank}
                        </div>
                      ) : (
                        <div class="text-2xl font-display font-bold text-gray-400">
                          {player.rank}
                        </div>
                      )}
                    </div>
                    
                    <!-- Player -->
                    <div class="col-span-5 flex items-center space-x-3">
                      <div class="relative w-12 h-12 rounded-full overflow-hidden ring-2 ring-primary-500/30">
                        <div class="absolute inset-0 bg-gradient-to-br from-primary-500 to-secondary-500"></div>
                        <img 
                          src={player.avatar}
                          alt={player.username}
                          class="absolute inset-0 w-full h-full object-cover z-10"
                          loading="lazy"
                        />
                      </div>
                      <div>
                        <div class="text-white font-bold">{player.username}</div>
                        {player.rank <= 3 && (
                          <div class="text-xs text-primary-500 font-semibold">Top Player</div>
                        )}
                      </div>
                    </div>
                    
                    <!-- Points -->
                    <div class="col-span-3 text-right">
                      <div class="text-white font-display font-bold text-lg">{player.points.toLocaleString()}</div>
                      <div class="text-xs text-gray-400">points</div>
                    </div>
                    
                    <!-- Prize -->
                    <div class="col-span-3 text-right">
                      <div class="text-primary-500 font-display font-black text-xl">{player.prize}</div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
            
            <!-- View Full Leaderboard -->
            <div class="p-6 bg-white/5 border-t border-white/10 text-center">
