---
import { withBase } from '../utils/paths';
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Us - Premium Casino">
  <!-- Hero Section -->
  <section class="relative min-h-[60vh] flex items-center justify-center overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0 z-0">
      <img 
        src="https://images.unsplash.com/photo-1596838132731-3301c3fd4317?w=1920&q=80" 
        alt="Luxury Casino Interior"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-dark-950/95 via-dark-900/90 to-dark-950/95"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
      <div class="inline-block px-4 py-2 bg-primary/10 border border-primary/20 rounded-full mb-6">
        <span class="text-primary font-semibold">Est. 2026</span>
      </div>
      
      <h1 class="font-display text-5xl md:text-7xl font-bold mb-6 bg-gradient-to-r from-primary via-yellow-400 to-primary bg-clip-text text-transparent">
        About Premium Casino
      </h1>
      
      <p class="text-xl md:text-2xl text-gray-300 max-w-3xl mx-auto mb-8">
        Leading the online gaming industry with innovation, integrity, and an unwavering commitment to player satisfaction since 2026.
      </p>

      <!-- Quick Stats -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-4xl mx-auto mt-12">
        <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-xl p-6">
          <div class="text-4xl md:text-5xl font-bold text-primary mb-2">1+</div>
          <div class="text-gray-400">Years Experience</div>
        </div>
        <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-xl p-6">
          <div class="text-4xl md:text-5xl font-bold text-primary mb-2">2M+</div>
          <div class="text-gray-400">Active Players</div>
        </div>
        <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-xl p-6">
          <div class="text-4xl md:text-5xl font-bold text-primary mb-2">150+</div>
          <div class="text-gray-400">Countries</div>
        </div>
        <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-xl p-6">
          <div class="text-4xl md:text-5xl font-bold text-primary mb-2">98%</div>
          <div class="text-gray-400">Satisfaction Rate</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Story Section -->
  <section class="py-20 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-block px-4 py-2 bg-primary/10 border border-primary/20 rounded-full mb-6">
            <span class="text-primary font-semibold">Our Story</span>
          </div>
          
          <h2 class="font-display text-4xl md:text-5xl font-bold mb-6 bg-gradient-to-r from-white to-gray-400 bg-clip-text text-transparent">
            A Journey of Excellence
          </h2>
          
          <div class="space-y-4 text-gray-300 text-lg">
            <p>
              Founded in 2026, Premium Casino was born from a vision to revolutionize the online gaming experience. What started as a small team of passionate gaming enthusiasts has grown into one of the most trusted and innovative online casinos in the industry.
            </p>
            <p>
              Our journey has been marked by continuous innovation, unwavering commitment to player satisfaction, and a dedication to responsible gaming. We've built our reputation on transparency, fairness, and delivering an unparalleled gaming experience.
            </p>
            <p>
              Today, we serve over 2 million players across 150+ countries, offering thousands of premium games from the world's leading providers. Our success is measured not just in numbers, but in the trust and loyalty of our global community.
            </p>
          </div>
        </div>

        <div class="relative">
          <div class="relative rounded-2xl overflow-hidden">
            <img 
              src="https://images.unsplash.com/photo-1511512578047-dfb367046420?w=800&q=80" 
              alt="Casino Team"
              class="w-full h-[500px] object-cover"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-dark-950/80 to-transparent"></div>
          </div>
          
          <!-- Floating Stats Card -->
          <div class="absolute -bottom-6 -left-6 bg-dark-800 border border-primary/20 rounded-xl p-6 backdrop-blur-sm">
            <div class="text-3xl font-bold text-primary mb-1">$2.5B+</div>
            <div class="text-gray-400">Total Winnings Paid</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Mission & Vision -->
  <section class="py-20 bg-dark-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <div class="inline-block px-4 py-2 bg-primary/10 border border-primary/20 rounded-full mb-6">
          <span class="text-primary font-semibold">Mission & Vision</span>
        </div>
        
        <h2 class="font-display text-4xl md:text-5xl font-bold mb-6 bg-gradient-to-r from-white to-gray-400 bg-clip-text text-transparent">
          What Drives Us Forward
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- Mission -->
        <div class="relative group">
          <div class="absolute inset-0 bg-gradient-to-r from-primary/20 to-secondary/20 rounded-2xl blur-xl group-hover:blur-2xl transition-all duration-300"></div>
          <div class="relative bg-dark-800 border border-white/10 rounded-2xl p-8 h-full">
            <div class="w-16 h-16 bg-gradient-to-br from-primary to-yellow-600 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
            
            <h3 class="font-display text-2xl font-bold text-white mb-4">Our Mission</h3>
            
            <p class="text-gray-300 text-lg leading-relaxed">
              To provide the world's most entertaining, secure, and fair online gaming experience while promoting responsible gambling and maintaining the highest standards of player protection and satisfaction.
            </p>
          </div>
        </div>

        <!-- Vision -->
        <div class="relative group">
          <div class="absolute inset-0 bg-gradient-to-r from-secondary/20 to-primary/20 rounded-2xl blur-xl group-hover:blur-2xl transition-all duration-300"></div>
          <div class="relative bg-dark-800 border border-white/10 rounded-2xl p-8 h-full">
            <div class="w-16 h-16 bg-gradient-to-br from-secondary to-purple-600 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
              </svg>
            </div>
            
            <h3 class="font-display text-2xl font-bold text-white mb-4">Our Vision</h3>
            
            <p class="text-gray-300 text-lg leading-relaxed">
              To be the global leader in online gaming innovation, setting industry standards for excellence, trust, and player experience while expanding our reach to create a worldwide community of satisfied players.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Core Values -->
  <section class="py-20 bg-gradient-to-b from-dark-900 to-dark-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <div class="inline-block px-4 py-2 bg-primary/10 border border-primary/20 rounded-full mb-6">
          <span class="text-primary font-semibold">Core Values</span>
        </div>
        
        <h2 class="font-display text-4xl md:text-5xl font-bold mb-6 bg-gradient-to-r from-white to-gray-400 bg-clip-text text-transparent">
          The Principles We Live By
        </h2>
        
        <p class="text-xl text-gray-400 max-w-3xl mx-auto">
          Our values guide every decision we make and every interaction we have with our players.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Value 1 -->
        <div class="bg-dark-800 border border-white/10 rounded-xl p-8 hover:border-primary/50 transition-all duration-300 group">
          <div class="w-14 h-14 bg-gradient-to-br from-primary to-yellow-600 rounded-lg flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
          </div>
          <h3 class="font-display text-xl font-bold text-white mb-3">Integrity</h3>
          <p class="text-gray-400">
            We operate with complete transparency and honesty, ensuring fair play and ethical business practices in everything we do.
          </p>
        </div>

        <!-- Value 2 -->
        <div class="bg-dark-800 border border-white/10 rounded-xl p-8 hover:border-primary/50 transition-all duration-300 group">
          <div class="w-14 h-14 bg-gradient-to-br from-secondary to-purple-600 rounded-lg flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="font-display text-xl font-bold text-white mb-3">Innovation</h3>
          <p class="text-gray-400">
            We continuously push boundaries, embracing cutting-edge technology to deliver the best gaming experience possible.
          </p>
        </div>

        <!-- Value 3 -->
        <div class="bg-dark-800 border border-white/10 rounded-xl p-8 hover:border-primary/50 transition-all duration-300 group">
          <div class="w-14 h-14 bg-gradient-to-br from-green-500 to-emerald-600 rounded-lg flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
            </svg>
          </div>
          <h3 class="font-display text-xl font-bold text-white mb-3">Player-Centric</h3>
          <p class="text-gray-400">
            Our players are at the heart of everything we do. Their satisfaction and safety are our top priorities.
          </p>
        </div>

        <!-- Value 4 -->
        <div class="bg-dark-800 border border-white/10 rounded-xl p-8 hover:border-primary/50 transition-all duration-300 group">
          <div class="w-14 h-14 bg-gradient-to-br from-blue-500 to-cyan-600 rounded-lg flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
            </svg>
          </div>
          <h3 class="font-display text-xl font-bold text-white mb-3">Security</h3>
          <p class="text-gray-400">
            We employ state-of-the-art security measures to protect player data and ensure safe, secure transactions.
          </p>
        </div>

        <!-- Value 5 -->
        <div class="bg-dark-800 border border-white/10 rounded-xl p-8 hover:border-primary/50 transition-all duration-300 group">
          <div class="w-14 h-14 bg-gradient-to-br from-red-500 to-pink-600 rounded-lg flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
            </svg>
          </div>
          <h3 class="font-display text-xl font-bold text-white mb-3">Responsibility</h3>
          <p class="text-gray-400">
            We promote responsible gaming and provide tools and support to ensure a safe and enjoyable experience for all.
          </p>
        </div>

        <!-- Value 6 -->
        <div class="bg-dark-800 border border-white/10 rounded-xl p-8 hover:border-primary/50 transition-all duration-300 group">
          <div class="w-14 h-14 bg-gradient-to-br from-orange-500 to-amber-600 rounded-lg flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path>
            </svg>
          </div>
          <h3 class="font-display text-xl font-bold text-white mb-3">Excellence</h3>
          <p class="text-gray-400">
            We strive for excellence in every aspect of our service, from game selection to customer support.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>

  <!-- Our Achievements -->
  <section class="py-20 bg-dark-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <div class="inline-block px-4 py-2 bg-primary/10 border border-primary/20 rounded-full mb-6">
          <span class="text-primary font-semibold">Achievements</span>
        </div>
        
        <h2 class="font-display text-4xl md:text-5xl font-bold mb-6 bg-gradient-to-r from-white to-gray-400 bg-clip-text text-transparent">
          Awards & Recognition
        </h2>
        
        <p class="text-xl text-gray-400 max-w-3xl mx-auto">
          Our commitment to excellence has been recognized by industry leaders worldwide.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Achievement 1 -->
        <div class="bg-gradient-to-br from-dark-800 to-dark-900 border border-primary/20 rounded-xl p-6 text-center hover:border-primary/50 transition-all duration-300">
          <div class="w-20 h-20 bg-gradient-to-br from-primary to-yellow-600 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-10 h-10 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
            </svg>
          </div>
          <h3 class="font-display text-lg font-bold text-white mb-2">Best Online Casino</h3>
          <p class="text-primary font-semibold mb-1">2024</p>
          <p class="text-gray-400 text-sm">Gaming Awards</p>
        </div>

        <!-- Achievement 2 -->
        <div class="bg-gradient-to-br from-dark-800 to-dark-900 border border-secondary/20 rounded-xl p-6 text-center hover:border-secondary/50 transition-all duration-300">
          <div class="w-20 h-20 bg-gradient-to-br from-secondary to-purple-600 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-10 h-10 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
            </svg>
          </div>
          <h3 class="font-display text-lg font-bold text-white mb-2">Player's Choice</h3>
          <p class="text-secondary font-semibold mb-1">2024</p>
          <p class="text-gray-400 text-sm">Casino Review</p>
        </div>

        <!-- Achievement 3 -->
        <div class="bg-gradient-to-br from-dark-800 to-dark-900 border border-green-500/20 rounded-xl p-6 text-center hover:border-green-500/50 transition-all duration-300">
          <div class="w-20 h-20 bg-gradient-to-br from-green-500 to-emerald-600 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-10 h-10 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
            </svg>
          </div>
          <h3 class="font-display text-lg font-bold text-white mb-2">Best Mobile Casino</h3>
          <p class="text-green-500 font-semibold mb-1">2023</p>
          <p class="text-gray-400 text-sm">Mobile Gaming Awards</p>
        </div>

        <!-- Achievement 4 -->
        <div class="bg-gradient-to-br from-dark-800 to-dark-900 border border-blue-500/20 rounded-xl p-6 text-center hover:border-blue-500/50 transition-all duration-300">
          <div class="w-20 h-20 bg-gradient-to-br from-blue-500 to-cyan-600 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-10 h-10 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
            </svg>
          </div>
          <h3 class="font-display text-lg font-bold text-white mb-2">Excellence in Service</h3>
          <p class="text-blue-500 font-semibold mb-1">2023</p>
          <p class="text-gray-400 text-sm">Customer Service Awards</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Leadership Team -->
  <section class="py-20 bg-gradient-to-b from-dark-950 to-dark-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <div class="inline-block px-4 py-2 bg-primary/10 border border-primary/20 rounded-full mb-6">
          <span class="text-primary font-semibold">Leadership</span>
        </div>
        
        <h2 class="font-display text-4xl md:text-5xl font-bold mb-6 bg-gradient-to-r from-white to-gray-400 bg-clip-text text-transparent">
          Meet Our Leadership Team
        </h2>
        
        <p class="text-xl text-gray-400 max-w-3xl mx-auto">
          Experienced professionals dedicated to delivering excellence in online gaming.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- Team Member 1 -->
        <div class="group">
          <div class="relative overflow-hidden rounded-xl mb-4">
            <img 
              src="https://images.unsplash.com/photo-1560250097-0b93528c311a?w=400&q=80" 
              alt="CEO"
              class="w-full h-80 object-cover group-hover:scale-110 transition-transform duration-500"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-dark-950 via-dark-950/50 to-transparent opacity-60"></div>
          </div>
          <h3 class="font-display text-xl font-bold text-white mb-1">Michael Anderson</h3>
          <p class="text-primary font-semibold mb-2">Chief Executive Officer</p>
          <p class="text-gray-400 text-sm">15+ years in gaming industry</p>
        </div>

        <!-- Team Member 2 -->
        <div class="group">
          <div class="relative overflow-hidden rounded-xl mb-4">
            <img 
              src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=400&q=80" 
              alt="CTO"
              class="w-full h-80 object-cover group-hover:scale-110 transition-transform duration-500"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-dark-950 via-dark-950/50 to-transparent opacity-60"></div>
          </div>
          <h3 class="font-display text-xl font-bold text-white mb-1">Sarah Mitchell</h3>
          <p class="text-primary font-semibold mb-2">Chief Technology Officer</p>
          <p class="text-gray-400 text-sm">Tech innovation expert</p>
        </div>

        <!-- Team Member 3 -->
        <div class="group">
          <div class="relative overflow-hidden rounded-xl mb-4">
            <img 
              src="https://images.unsplash.com/photo-1519085360753-af0119f7cbe7?w=400&q=80" 
              alt="COO"
              class="w-full h-80 object-cover group-hover:scale-110 transition-transform duration-500"
              loading="lazy"
            />
