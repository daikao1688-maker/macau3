    description: 'Manage your account safely',
    articleCount: 15,
    color: 'from-secondary-500 to-purple-600'
  },
  {
    id: 3,
    name: 'Deposits & Withdrawals',
    icon: '💳',
    description: 'Payment methods and transactions',
    articleCount: 18,
    color: 'from-accent-green to-emerald-600'
  },
  {
    id: 4,
    name: 'Games & Features',
    icon: '🎮',
    description: 'Learn about our games',
    articleCount: 25,
    color: 'from-accent-blue to-blue-600'
  },
  {
    id: 5,
