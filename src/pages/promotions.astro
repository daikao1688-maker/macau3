    badge: 'Special Occasion',
    color: 'from-pink-500 via-rose-600 to-red-600',
    icon: '🎂',
    code: 'BIRTHDAY100',
    category: 'Special Bonus',
    validUntil: 'Your Birthday',
    minDeposit: '$25',
    wagering: '30x',
    image: 'https://images.unsplash.com/photo-1464618663641-bbdd760ae84a?w=800&h=400&fit=crop&q=80',
    featured: false
  },
  {
    id: 8,
    title: 'Refer a Friend',
    description: 'Get $500 for each friend you refer + they get $200 bonus',
    badge: 'Referral Program',
    color: 'from-cyan-500 via-blue-600 to-indigo-600',
    icon: '👥',
    code: 'REFER500',
    category: 'Referral',
