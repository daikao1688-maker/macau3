  },
  {
    id: 5,
    title: 'Live Casino Bonus',
    description: '50% bonus up to $3,000 exclusively for live dealer games',
    badge: 'Live Gaming',
    color: 'from-blue-500 via-indigo-600 to-purple-600',
    icon: '🎥',
    code: 'LIVE50',
    category: 'Live Casino',
    validUntil: 'Ongoing',
    minDeposit: '$100',
    wagering: '40x',
    image: 'https://images.unsplash.com/photo-1596838132731-3301c3fd4317?w=800&h=400&fit=crop&q=80',
    featured: false
  },
  {
    id: 6,
    title: 'Loyalty Rewards',
    description: 'Earn points on every bet and exchange for cash or prizes',
